/-!
# Simon's theorem (1975) — statement level

PRD E5 Target A: a **sorry-free statement** of Simon's theorem (proof
incremental). A regular language is piecewise testable iff its syntactic monoid
is `𝓙`-trivial.

`IsPiecewiseTestable` is defined as the Boolean subalgebra generated by the
scattered-subword up-sets `{w | u <+ w}` (`<+` is `List.Sublist`, the scattered
subsequence relation; `FreeMonoid α` is definitionally `List α`). Regularity is
encoded by `[Finite (SyntacticMonoid L)]` (a language is regular iff its
syntactic monoid is finite — Myhill–Nerode).
-/

namespace DualityEngine

variable {α : Type*}

/-- Scattered-subword up-set: words containing `u` as a subsequence. -/
def subwordUpset (u : FreeMonoid α) : Set (FreeMonoid α) :=
  {w | (FreeMonoid.toList u).Sublist (FreeMonoid.toList w)}

/-- **Piecewise-testable languages**: the Boolean subalgebra of `Set (FreeMonoid α)`
generated by the scattered-subword up-sets. Finite derivations ⟺ Boolean
combinations of finitely many subword conditions. -/
inductive IsPiecewiseTestable : Set (FreeMonoid α) → Prop
  | basic (u : FreeMonoid α) : IsPiecewiseTestable (subwordUpset u)
  | empty : IsPiecewiseTestable (∅ : Set (FreeMonoid α))
  | compl {L : Set (FreeMonoid α)} : IsPiecewiseTestable L → IsPiecewiseTestable Lᶜ
  | union {L₁ L₂ : Set (FreeMonoid α)} :
      IsPiecewiseTestable L₁ → IsPiecewiseTestable L₂ → IsPiecewiseTestable (L₁ ∪ L₂)

/-! ## Genuinely proved building blocks (sorry-free) -/

/-- **Complement-invariance of the syntactic congruence.** A language and its
complement induce the *same* syntactic congruence — interchangeability in all
contexts is insensitive to negating membership (`¬a ↔ ¬b ↔ (a ↔ b)`). -/
theorem syntacticCon_compl (L : Set (FreeMonoid α)) :
    syntacticCon Lᶜ = syntacticCon L := by
  ext u v
  show (∀ x y, x * u * y ∈ Lᶜ ↔ x * v * y ∈ Lᶜ) ↔
       (∀ x y, x * u * y ∈ L ↔ x * v * y ∈ L)
  simp only [Set.mem_compl_iff, not_iff_not]

/-- Hence a language and its complement have the **same syntactic monoid** — the
algebraic dual object is complement-invariant (the formal counterpart of the
Axis-A finding that complement never changes variety membership). -/
theorem syntacticMonoid_compl (L : Set (FreeMonoid α)) :
    SyntacticMonoid Lᶜ = SyntacticMonoid L := by
  unfold SyntacticMonoid
  rw [syntacticCon_compl]

/-- Transport `𝓙`-triviality along an equality of congruences. Stated for VARIABLE
congruences so it goes by `subst` (clean — no ill-typed motive from rewriting
under the `Monoid` instance). -/
theorem isJTrivial_quotient_congr {c d : Con (FreeMonoid α)} (h : c = d) :
    IsJTrivial c.Quotient ↔ IsJTrivial d.Quotient := by
  subst h; exact Iff.rfl

/-- The empty language's syntactic congruence relates ALL words (every context
sends every word outside `∅`), so its **syntactic monoid is trivial**. -/
instance subsingleton_syntacticMonoid_empty :
    Subsingleton (SyntacticMonoid (∅ : Set (FreeMonoid α))) := by
  constructor
  intro a b
  induction a using Quotient.inductionOn with
  | _ u =>
    induction b using Quotient.inductionOn with
    | _ v =>
      apply Quotient.sound
      intro x y
      simp only [Set.mem_empty_iff_false]

/-! ## The irreducible hard cores, isolated (Simon's theorem is publication-scale)

NOTE ON FINITENESS (corrected, 3rd session): the union argument needs the
**finite-DOMAIN** quotient-closure of `𝓙`-triviality. Quotient-closure is FALSE in
general (`(ℕ,+) ↠ ℤ/2ℤ`); the infinite object there is the DOMAIN `ℕ`, while the
codomain `ℤ/2ℤ` is finite — so the fix is `[Finite M]` on the domain, NOT `[Finite
N]` on the codomain (an earlier session pinned it to the wrong side; see
`Green.isJTrivial_of_surjHom`). The forward induction therefore threads finiteness
of the DOMAIN: the surjection's domain is the meet-quotient, which embeds into the
finite product `M(L₁)×M(L₂)` (`unionEmbed_injective`), so it is finite whenever both
factors are. `finite_syntacticMonoid_union` then transports finiteness to the union
itself for the `Finite ∧ IsJTrivial` conjunction. -/

/-- The meet of the two syntactic congruences **refines** the union's: if `u, v`
are interchangeable for both `L₁` and `L₂`, they are interchangeable for `L₁∪L₂`. -/
theorem syntacticCon_inf_le_union (L₁ L₂ : Set (FreeMonoid α)) :
    syntacticCon L₁ ⊓ syntacticCon L₂ ≤ syntacticCon (L₁ ∪ L₂) := by
  intro u v h
  obtain ⟨h1, h2⟩ := h
  intro x y
  constructor
  · rintro (hL | hL)
    · exact Or.inl ((h1 x y).mp hL)
    · exact Or.inr ((h2 x y).mp hL)
  · rintro (hL | hL)
    · exact Or.inl ((h1 x y).mpr hL)
    · exact Or.inr ((h2 x y).mpr hL)

/-- The canonical injection of the meet-quotient into the product (well-defined as
the meet refines each factor; injective as equality in both factors is meet-equality). -/
def unionEmbed (L₁ L₂ : Set (FreeMonoid α)) :
    (syntacticCon L₁ ⊓ syntacticCon L₂).Quotient →*
      (SyntacticMonoid L₁ × SyntacticMonoid L₂) :=
  Con.lift _ ((syntacticMorphism L₁).prod (syntacticMorphism L₂)) (by
    intro u v h; obtain ⟨h1, h2⟩ := h; ext
    · exact (Con.eq _).mpr h1
    · exact (Con.eq _).mpr h2)

theorem unionEmbed_injective (L₁ L₂ : Set (FreeMonoid α)) :
    Function.Injective (unionEmbed L₁ L₂) := by
  intro a b hab
  induction a using Quotient.inductionOn with
  | _ u =>
    induction b using Quotient.inductionOn with
    | _ v =>
      exact Quotient.sound ⟨(Con.eq _).mp (congrArg Prod.fst hab),
                            (Con.eq _).mp (congrArg Prod.snd hab)⟩

/-- The surjection of the meet-quotient onto `M(L₁∪L₂)` (the meet refines the union). -/
def unionProject (L₁ L₂ : Set (FreeMonoid α)) :
    (syntacticCon L₁ ⊓ syntacticCon L₂).Quotient →* SyntacticMonoid (L₁ ∪ L₂) :=
  Con.lift _ (syntacticCon (L₁ ∪ L₂)).mk'
    (fun _ _ h => (Con.eq _).mpr (syntacticCon_inf_le_union L₁ L₂ h))

theorem unionProject_surjective (L₁ L₂ : Set (FreeMonoid α)) :
    Function.Surjective (unionProject L₁ L₂) := by
  apply Con.lift_surjective_of_surjective
  exact Con.mk'_surjective

/-- **Finiteness transports through the union** (pure inj/surj transport, sorry-free):
`M(L₁∪L₂)` is finite when `M(L₁)`, `M(L₂)` are. -/
theorem finite_syntacticMonoid_union {L₁ L₂ : Set (FreeMonoid α)}
    [Finite (SyntacticMonoid L₁)] [Finite (SyntacticMonoid L₂)] :
    Finite (SyntacticMonoid (L₁ ∪ L₂)) := by
  haveI : Finite (syntacticCon L₁ ⊓ syntacticCon L₂).Quotient :=
    Finite.of_injective _ (unionEmbed_injective L₁ L₂)
  exact Finite.of_surjective _ (unionProject_surjective L₁ L₂)

/-- The subword up-set of the EMPTY word is everything (`ε <+ w` always). -/
theorem subwordUpset_one : subwordUpset (1 : FreeMonoid α) = Set.univ := by
  ext w
  simp only [subwordUpset, Set.mem_setOf_eq, Set.mem_univ, iff_true]
  exact List.nil_sublist _

/-- The syntactic monoid of `Set.univ` is trivial (all words interchangeable). -/
instance subsingleton_syntacticMonoid_univ :
    Subsingleton (SyntacticMonoid (Set.univ : Set (FreeMonoid α))) := by
  constructor
  intro a b
  induction a using Quotient.inductionOn with
  | _ u =>
    induction b using Quotient.inductionOn with
    | _ v =>
      apply Quotient.sound
      intro x y
      simp only [Set.mem_univ]

/-! ### Greedy subword recognition (verified core toward `pt_basic`)

The automaton recognising `subwordUpset u`: a state is the suffix of `u` still to be
matched; reading `a` consumes the head iff it equals `a`. `gmatch s w` is the suffix of
`s` left unmatched after greedily reading `w` left-to-right. The key theorem
`gmatch_nil_iff` (**greedy subword matching is optimal**) is the combinatorial heart of
`pt_basic`; it is proved here sorry-free. -/

/-- One greedy step: consume the head of `s` iff it equals `a`. -/
def gstep [DecidableEq α] (s : List α) (a : α) : List α :=
  match s with
  | [] => []
  | b :: s' => if b = a then s' else b :: s'

/-- Greedily match `s` against `w`, returning the unmatched suffix of `s`. -/
def gmatch [DecidableEq α] (s w : List α) : List α := w.foldl gstep s

theorem gmatch_cons [DecidableEq α] (s : List α) (a : α) (w : List α) :
    gmatch s (a :: w) = gmatch (gstep s a) w := rfl

theorem gstep_sublist [DecidableEq α] (s : List α) (a : α) (w' : List α) :
    List.Sublist s (a :: w') ↔ List.Sublist (gstep s a) w' := by
  cases s with
  | nil => simp [gstep, List.nil_sublist]
  | cons b s' =>
    simp only [gstep]
    by_cases hba : b = a
    · subst hba; rw [if_pos rfl]; exact List.cons_sublist_cons
    · rw [if_neg hba]
      constructor
      · intro h
        cases h with
        | cons _ h' => exact h'
        | cons₂ _ h' => exact absurd rfl hba
      · intro h; exact h.cons a

/-- **Greedy subword matching is optimal** (verified, sorry-free): `gmatch s w = []` iff
`s` is a scattered subword of `w`. This is the combinatorial core of `pt_basic` — that
greedily consuming each matched letter never loses a match. -/
theorem gmatch_nil_iff [DecidableEq α] (s w : List α) :
    gmatch s w = [] ↔ List.Sublist s w := by
  induction w generalizing s with
  | nil => simp [gmatch, List.sublist_nil]
  | cons a w' ih => rw [gmatch_cons, ih, ← gstep_sublist]

/-! ### The greedy transition monoid (finite, `𝓙`-trivial)

States = suffixes of `u`; `act u w` is the greedy action (`σ ↦ gmatch σ w`), a monotone
inflationary self-map. The transition congruence `tcon u` (words with equal action)
refines `syntacticCon (subwordUpset u)` (recognition), its quotient is finite (injects
into the finite function space) and `𝓙`-trivial (directly, by the inflationary argument),
and `SyntacticMonoid` is its surjective image. -/

theorem gmatch_suffix [DecidableEq α] (s w : List α) : (gmatch s w) <:+ s := by
  induction w generalizing s with
  | nil => simp [gmatch]
  | cons a w' ih =>
    refine (ih (gstep s a)).trans ?_
    cases s with
    | nil => simp [gstep]
    | cons b s' =>
      simp only [gstep]; by_cases h : b = a
      · rw [if_pos h]; exact List.suffix_cons b s'
      · rw [if_neg h]

theorem gmatch_mono [DecidableEq α] {s' s : List α} (h : s' <:+ s) (w : List α) :
    (gmatch s' w) <:+ (gmatch s w) := by
  induction w generalizing s' s with
  | nil => simpa [gmatch] using h
  | cons a w' ih =>
    refine ih ?_
    cases s with
    | nil => rw [List.suffix_nil.mp h]
    | cons b s₀ =>
      rcases (List.suffix_cons_iff.mp h) with rfl | h'
      · exact List.suffix_rfl
      · have h1 : gstep s' a <:+ s' := by
          cases s' with
          | nil => simp [gstep]
          | cons c s'' => simp only [gstep]; by_cases hc : c = a
                          · rw [if_pos hc]; exact List.suffix_cons c s''
                          · rw [if_neg hc]
        have h2 : s₀ <:+ gstep (b :: s₀) a := by
          simp only [gstep]; by_cases hb : b = a
          · rw [if_pos hb]
          · rw [if_neg hb]; exact List.suffix_cons b s₀
        exact (h1.trans h').trans h2

theorem gmatch_append [DecidableEq α] (s v w : List α) :
    gmatch s (v ++ w) = gmatch (gmatch s v) w := by
  simp only [gmatch, List.foldl_append]

theorem suffix_eq_of_length {t t' u : List α} (h : t <:+ u) (h' : t' <:+ u)
    (hl : t.length = t'.length) : t = t' := by
  obtain ⟨p, hp⟩ := h; obtain ⟨p', hp'⟩ := h'
  have heq : p ++ t = p' ++ t' := by rw [hp, hp']
  have hpl : p.length = p'.length := by
    have := congrArg List.length heq; simp only [List.length_append] at this; omega
  exact List.append_inj_right heq hpl

/-- States of the subword automaton: the suffixes of `u`. -/
def St (u : List α) := {s : List α // s <:+ u}

instance instFiniteSt (u : List α) : Finite (St u) := by
  have hb : ∀ σ : St u, σ.1.length ≤ u.length := by
    intro σ; obtain ⟨p, hp⟩ := σ.2
    have := congrArg List.length hp; simp only [List.length_append] at this; omega
  apply Finite.of_injective
    (fun σ : St u => (⟨σ.1.length, Nat.lt_succ_of_le (hb σ)⟩ : Fin (u.length + 1)))
  rintro ⟨s, hs⟩ ⟨s', hs'⟩ h
  simp only [Fin.mk.injEq] at h
  exact Subtype.ext (suffix_eq_of_length hs hs' h)

/-- Order on states: `σ ≤ τ` iff `τ` is a suffix of `σ` (further-matched is bigger). -/
instance instPOSt (u : List α) : PartialOrder (St u) where
  le σ τ := τ.1 <:+ σ.1
  le_refl σ := List.suffix_rfl
  le_trans a b c hab hbc := hbc.trans hab
  le_antisymm a b hab hba := by
    apply Subtype.ext
    exact hba.sublist.eq_of_length (le_antisymm hba.length_le hab.length_le)

/-- The greedy action of a word on the states. -/
def act [DecidableEq α] (u w : List α) (σ : St u) : St u :=
  ⟨gmatch σ.1 w, (gmatch_suffix σ.1 w).trans σ.2⟩

theorem act_infl [DecidableEq α] (u w : List α) (σ : St u) : σ ≤ act u w σ :=
  gmatch_suffix σ.1 w
theorem act_mono [DecidableEq α] (u w : List α) : Monotone (act u w) :=
  fun _ _ h => gmatch_mono h w
theorem act_append [DecidableEq α] (u v w : List α) (σ : St u) :
    act u (v ++ w) σ = act u w (act u v σ) := Subtype.ext (gmatch_append σ.1 v w)

/-- The transition congruence: words with equal greedy action. -/
def tcon [DecidableEq α] (u : FreeMonoid α) : Con (FreeMonoid α) where
  r v v' := act (FreeMonoid.toList u) (FreeMonoid.toList v)
          = act (FreeMonoid.toList u) (FreeMonoid.toList v')
  iseqv := ⟨fun _ => rfl, fun h => h.symm, fun h1 h2 => h1.trans h2⟩
  mul' := by
    intro v v' w w' hv hw
    funext σ
    rw [FreeMonoid.toList_mul, FreeMonoid.toList_mul, act_append, act_append,
        congrFun hv σ, congrFun hw _]

/-- **Recognition refinement**: equal greedy action ⟹ syntactically equivalent for
`subwordUpset u`. Uses `gmatch_nil_iff` (`u ⊑ xvy ⟺ gmatch u (xvy) = []`). -/
theorem tcon_le [DecidableEq α] (u v v' : FreeMonoid α) (h : tcon u v v') :
    syntacticCon (subwordUpset u) v v' := by
  intro x y
  have key : ∀ w : FreeMonoid α,
      gmatch (FreeMonoid.toList u) (FreeMonoid.toList (x * w * y))
      = (act (FreeMonoid.toList u) (FreeMonoid.toList y)
          (act (FreeMonoid.toList u) (FreeMonoid.toList w)
            (act (FreeMonoid.toList u) (FreeMonoid.toList x)
              ⟨FreeMonoid.toList u, List.suffix_refl _⟩))).1 := by
    intro w
    rw [FreeMonoid.toList_mul, FreeMonoid.toList_mul, gmatch_append, gmatch_append]
    rfl
  have heq : gmatch (FreeMonoid.toList u) (FreeMonoid.toList (x * v * y))
           = gmatch (FreeMonoid.toList u) (FreeMonoid.toList (x * v' * y)) := by
    rw [key v, key v', congrFun h _]
  show (FreeMonoid.toList u).Sublist (FreeMonoid.toList (x * v * y))
     ↔ (FreeMonoid.toList u).Sublist (FreeMonoid.toList (x * v' * y))
  rw [← gmatch_nil_iff, ← gmatch_nil_iff, heq]

instance instFiniteTconQ [DecidableEq α] (u : FreeMonoid α) : Finite ((tcon u).Quotient) := by
  apply Finite.of_injective
    (fun q : (tcon u).Quotient =>
      Quotient.liftOn q (fun v => act (FreeMonoid.toList u) (FreeMonoid.toList v))
        (fun _ _ h => h))
  intro a b
  refine Quotient.inductionOn₂ a b (fun v v' h => Quotient.sound h)

/-- **`𝓙`-triviality of the transition quotient**, directly: from `[v] = [x·v'·y]` the
inflationary/monotone action gives `act v ≥ act v'` pointwise; symmetrically `≤`; so the
actions are equal, i.e. `[v] = [v']`. -/
theorem tcon_jtrivial [DecidableEq α] (u : FreeMonoid α) : IsJTrivial ((tcon u).Quotient) := by
  have act_ge : ∀ (v x v' y : FreeMonoid α),
      act (FreeMonoid.toList u) (FreeMonoid.toList v)
        = act (FreeMonoid.toList u) (FreeMonoid.toList (x * v' * y)) →
      ∀ σ, act (FreeMonoid.toList u) (FreeMonoid.toList v') σ
         ≤ act (FreeMonoid.toList u) (FreeMonoid.toList v) σ := by
    intro v x v' y hc σ
    have e : act (FreeMonoid.toList u) (FreeMonoid.toList v) σ
        = act (FreeMonoid.toList u) (FreeMonoid.toList y)
            (act (FreeMonoid.toList u) (FreeMonoid.toList v')
              (act (FreeMonoid.toList u) (FreeMonoid.toList x) σ)) := by
      rw [hc, FreeMonoid.toList_mul, FreeMonoid.toList_mul, act_append, act_append]
    rw [e]
    calc act (FreeMonoid.toList u) (FreeMonoid.toList v') σ
        ≤ act (FreeMonoid.toList u) (FreeMonoid.toList v')
            (act (FreeMonoid.toList u) (FreeMonoid.toList x) σ) :=
          act_mono _ _ (act_infl _ _ σ)
      _ ≤ _ := act_infl _ _ _
  intro A B hab
  obtain ⟨v, rfl⟩ := Quotient.exists_rep A
  obtain ⟨v', rfl⟩ := Quotient.exists_rep B
  obtain ⟨S, T, hST⟩ := hab.1
  obtain ⟨x, rfl⟩ := Quotient.exists_rep S
  obtain ⟨y, rfl⟩ := Quotient.exists_rep T
  obtain ⟨S', T', hS'T'⟩ := hab.2
  obtain ⟨x', rfl⟩ := Quotient.exists_rep S'
  obtain ⟨y', rfl⟩ := Quotient.exists_rep T'
  have hcv : tcon u v (x * v' * y) := Quotient.exact hST
  have hcv' : tcon u v' (x' * v * y') := Quotient.exact hS'T'
  apply Quotient.sound
  funext σ
  exact le_antisymm (act_ge v' x' v y' hcv' σ) (act_ge v x v' y hcv σ)

/-- HARD CORE 1 (forward, `basic` case): the scattered-subword up-set is regular
(finite syntactic monoid) and `𝓙`-trivial. Simon's subword combinatorics.

**FULLY PROVED (sorry-free).** Via the greedy transition monoid above: states are the
suffixes of `u` (`St`, finite); `act u w` is the monotone inflationary greedy action;
the transition congruence `tcon u` refines `syntacticCon (subwordUpset u)` (`tcon_le`,
recognition through `gmatch_nil_iff`); its quotient is finite (`instFiniteTconQ`) and
`𝓙`-trivial (`tcon_jtrivial`, the direct inflationary argument). `SyntacticMonoid` is the
surjective image (`Con.lift`), so finite (`Finite.of_surjective`) and `𝓙`-trivial
(`Green.isJTrivial_of_surjHom`). -/
theorem pt_basic (u : FreeMonoid α) :
    Finite (SyntacticMonoid (subwordUpset u)) ∧
    IsJTrivial (SyntacticMonoid (subwordUpset u)) := by
  classical
  haveI := instFiniteTconQ u
  let g : (tcon u).Quotient →* SyntacticMonoid (subwordUpset u) :=
    Con.lift (tcon u) ((syntacticCon (subwordUpset u)).mk')
      (fun a b h => (Con.eq _).mpr (tcon_le u a b h))
  have hg : Function.Surjective g := by
    apply Con.lift_surjective_of_surjective
    exact Con.mk'_surjective
  exact ⟨Finite.of_surjective g hg, isJTrivial_of_surjHom g hg (tcon_jtrivial u)⟩

/-- The `u = ε` base case of `pt_basic`, proved sorry-free. -/
theorem pt_basic_one :
    Finite (SyntacticMonoid (subwordUpset (1 : FreeMonoid α))) ∧
    IsJTrivial (SyntacticMonoid (subwordUpset (1 : FreeMonoid α))) := by
  rw [subwordUpset_one]
  exact ⟨Finite.of_subsingleton, isJTrivial_of_subsingleton _⟩

/-- `𝓙`-triviality is preserved by union via `isJTrivial_of_surjHom` (finite-DOMAIN
quotient-closure), which is **now fully proved sorry-free** (`Green`: stability +
the converse `jtrivial_of_identities`). The surjection's domain is the meet-quotient,
which is finite (it embeds into the finite product `M(L₁)×M(L₂)` via
`unionEmbed_injective`) — exactly the `[Finite M]` needed. **`jtrivial_union` is now
entirely sorry-free.** -/
theorem jtrivial_union {L₁ L₂ : Set (FreeMonoid α)}
    [Finite (SyntacticMonoid L₁)] [Finite (SyntacticMonoid L₂)]
    (h₁ : IsJTrivial (SyntacticMonoid L₁)) (h₂ : IsJTrivial (SyntacticMonoid L₂)) :
    IsJTrivial (SyntacticMonoid (L₁ ∪ L₂)) := by
  haveI : Finite (syntacticCon L₁ ⊓ syntacticCon L₂).Quotient :=
    Finite.of_injective _ (unionEmbed_injective L₁ L₂)
  exact isJTrivial_of_surjHom (unionProject L₁ L₂) (unionProject_surjective L₁ L₂)
    (isJTrivial_of_injHom (unionEmbed L₁ L₂) (unionEmbed_injective L₁ L₂)
      (isJTrivial_prod h₁ h₂))

/-- The DEGENERATE case of the converse: if the syntactic monoid is **trivial**
(`|M|=1`), the language is `∅` or `univ` (every word is interchangeable with `ε`),
both piecewise testable. Proved sorry-free.

**This does NOT advance the general converse** — `IsJTrivial` does not imply
`Subsingleton` (e.g. `M(Σ*aΣ*bΣ*)` has 5 elements and is `𝓙`-trivial). It is only
the `|M|=1` fragment. -/
theorem pt_of_jtrivial_subsingleton (L : Set (FreeMonoid α))
    [Subsingleton (SyntacticMonoid L)] : IsPiecewiseTestable L := by
  have key : ∀ w : FreeMonoid α, w ∈ L ↔ (1 : FreeMonoid α) ∈ L := by
    intro w
    have he : (syntacticMorphism L) w = (syntacticMorphism L) 1 := Subsingleton.elim _ _
    have hc : syntacticCon L w 1 := (Con.eq _).mp he
    have := hc 1 1
    simpa using this
  by_cases h1 : (1 : FreeMonoid α) ∈ L
  · have hL : L = Set.univ := by ext w; simp [key w, h1]
    rw [hL, ← subwordUpset_one]
    exact IsPiecewiseTestable.basic 1
  · have hL : L = (∅ : Set (FreeMonoid α)) := by ext w; simp [key w, h1]
    rw [hL]; exact IsPiecewiseTestable.empty

/-! ## Simon's converse via the `∼ₖ` congruence (Klíma's proof)

We follow Ondřej Klíma, *Piecewise Testable Languages via Combinatorics on Words*.
The hard direction reduces to **Lemma 3** (`∼ₖ ⊆ ∼_L` for `k = 2·card(M)-2`); the
remaining infrastructure (PT closed under finite Boolean ops; congruence-level
`𝓙`-triviality; **Lemma 1**, the wrapping `∼ₖ ⊆ ∼_L ⟹ PT`) is proved sorry-free below. -/

/-- PT closed under finite unions. -/
theorem IsPiecewiseTestable.biUnion {ι : Type*} (F : Finset ι)
    (g : ι → Set (FreeMonoid α)) (hg : ∀ i ∈ F, IsPiecewiseTestable (g i)) :
    IsPiecewiseTestable (⋃ i ∈ F, g i) := by
  classical
  induction F using Finset.induction with
  | empty => simpa using IsPiecewiseTestable.empty
  | @insert a F' _ ih =>
    rw [Finset.set_biUnion_insert]
    exact (hg a (Finset.mem_insert_self a F')).union
          (ih (fun i hi => hg i (Finset.mem_insert_of_mem hi)))

/-- PT closed under finite intersections (`⋂ ∅ = univ = subwordUpset 1`). -/
theorem IsPiecewiseTestable.biInter {ι : Type*} (F : Finset ι)
    (g : ι → Set (FreeMonoid α)) (hg : ∀ i ∈ F, IsPiecewiseTestable (g i)) :
    IsPiecewiseTestable (⋂ i ∈ F, g i) := by
  classical
  induction F using Finset.induction with
  | empty =>
    have : (⋂ i ∈ (∅ : Finset ι), g i) = Set.univ := by simp
    rw [this, ← subwordUpset_one]; exact IsPiecewiseTestable.basic 1
  | @insert a F' _ ih =>
    rw [Finset.set_biInter_insert]
    have hrw : g a ∩ (⋂ i ∈ F', g i) = ((g a)ᶜ ∪ (⋂ i ∈ F', g i)ᶜ)ᶜ := by
      rw [Set.compl_union, compl_compl, compl_compl]
    rw [hrw]
    exact (((hg a (Finset.mem_insert_self a F')).compl).union
           ((ih (fun i hi => hg i (Finset.mem_insert_of_mem hi))).compl)).compl

/-- **Congruence-level `𝓙`-triviality** (Klíma's hypothesis form): if the syntactic monoid
is `𝓙`-trivial then `w₁w₂uw₃w₄ ∼_L u ⟹ w₂uw₃ ∼_L u`. -/
theorem con_jtrivial {L : Set (FreeMonoid α)} (h : IsJTrivial (SyntacticMonoid L))
    (u w₁ w₂ w₃ w₄ : FreeMonoid α)
    (hyp : syntacticCon L (w₁ * w₂ * u * w₃ * w₄) u) :
    syntacticCon L (w₂ * u * w₃) u := by
  have hφ : (syntacticMorphism L) (w₁ * w₂ * u * w₃ * w₄) = (syntacticMorphism L) u :=
    (Con.eq _).mpr hyp
  apply (Con.eq _).mp
  refine h (syntacticMorphism L (w₂ * u * w₃)) (syntacticMorphism L u)
    ⟨⟨syntacticMorphism L w₂, syntacticMorphism L w₃, ?_⟩,
     syntacticMorphism L w₁, syntacticMorphism L w₄, ?_⟩
  · simp only [map_mul]
  · have he : w₁ * w₂ * u * w₃ * w₄ = w₁ * (w₂ * u * w₃) * w₄ := by simp only [mul_assoc]
    rw [← hφ, he, map_mul, map_mul]

/-- **Lemma 1 (Klíma)** — the wrapping: if `∼ₖ` refines the syntactic congruence
(`u,v` agreeing on subwords of length `≤ k` are syntactically equivalent), then `L` is
piecewise testable. Each `∼ₖ`-class is the finite Boolean combination
`(⋂_{x⊑w,|x|≤k} ⟨x⟩) ∩ (⋂_{x⋪w,|x|≤k} ⟨x⟩ᶜ)` (finite as `α` is finite), and `L` is the
finite union of the classes it contains. -/
theorem pt_of_subk_refines [Finite α] {L : Set (FreeMonoid α)} (k : ℕ)
    (href : ∀ u v : FreeMonoid α,
      (∀ x : FreeMonoid α, x.length ≤ k → (u ∈ subwordUpset x ↔ v ∈ subwordUpset x)) →
      syntacticCon L u v) :
    IsPiecewiseTestable L := by
  classical
  set Bk : Finset (FreeMonoid α) := (List.finite_length_le α k).toFinset with hBkdef
  have hBkmem : ∀ x : FreeMonoid α, x ∈ Bk ↔ x.length ≤ k :=
    fun x => Set.Finite.mem_toFinset _
  let atom : Finset (FreeMonoid α) → Set (FreeMonoid α) :=
    fun T => ⋂ x ∈ Bk, (if x ∈ T then subwordUpset x else (subwordUpset x)ᶜ)
  have atomPT : ∀ T, IsPiecewiseTestable (atom T) := by
    intro T; apply IsPiecewiseTestable.biInter; intro x _
    by_cases hx : x ∈ T
    · simp only [if_pos hx]; exact IsPiecewiseTestable.basic x
    · simp only [if_neg hx]; exact (IsPiecewiseTestable.basic x).compl
  have atomMem : ∀ (T : Finset (FreeMonoid α)) (w : FreeMonoid α),
      w ∈ atom T ↔ ∀ x ∈ Bk, (w ∈ subwordUpset x ↔ x ∈ T) := by
    intro T w
    simp only [atom, Set.mem_iInter]
    constructor
    · intro hmem x hx
      have hthis := hmem x hx
      by_cases hxT : x ∈ T
      · simp only [if_pos hxT] at hthis; exact ⟨fun _ => hxT, fun _ => hthis⟩
      · simp only [if_neg hxT] at hthis
        exact ⟨fun hw => absurd hw hthis, fun hT => absurd hT hxT⟩
    · intro hmem x hx
      by_cases hxT : x ∈ T
      · simp only [if_pos hxT]; exact (hmem x hx).mpr hxT
      · simp only [if_neg hxT, Set.mem_compl_iff]
        exact fun hw => hxT ((hmem x hx).mp hw)
  let sig : FreeMonoid α → Finset (FreeMonoid α) :=
    fun w => Bk.filter (fun x => w ∈ subwordUpset x)
  have wInAtomSig : ∀ w, w ∈ atom (sig w) := by
    intro w; rw [atomMem]; intro x hx
    simp only [sig, Finset.mem_filter]
    exact ⟨fun hw => ⟨hx, hw⟩, fun h => h.2⟩
  have atomSub : ∀ w ∈ L, atom (sig w) ⊆ L := by
    intro w hw w' hw'
    rw [atomMem] at hw'
    have hsim : ∀ x : FreeMonoid α, x.length ≤ k →
        (w' ∈ subwordUpset x ↔ w ∈ subwordUpset x) := by
      intro x hxlen
      have hxBk : x ∈ Bk := (hBkmem x).mpr hxlen
      rw [hw' x hxBk]; simp only [sig, Finset.mem_filter]
      exact ⟨fun h => h.2, fun h => ⟨hxBk, h⟩⟩
    have hc := href w' w hsim
    have h11 := hc 1 1
    simpa using h11.mpr (by simpa using hw)
  have key : L = ⋃ T ∈ (Bk.powerset.filter (fun T => atom T ⊆ L)), atom T := by
    apply Set.eq_of_subset_of_subset
    · intro w hw
      rw [Set.mem_iUnion₂]
      refine ⟨sig w, ?_, wInAtomSig w⟩
      rw [Finset.mem_filter, Finset.mem_powerset]
      exact ⟨Finset.filter_subset _ _, atomSub w hw⟩
    · intro w hw
      rw [Set.mem_iUnion₂] at hw
      obtain ⟨T, hT, hwT⟩ := hw
      rw [Finset.mem_filter] at hT
      exact hT.2 hwT
  rw [key]
  exact IsPiecewiseTestable.biUnion _ _ (fun T _ => atomPT T)

/-! ### Building blocks toward Lemma 3 (verified) -/

/-- **Prefix-squeeze** (Claim-1 ingredient): if `φ(a·b₁·b₂) = φ(a)` then `φ(a·b₁) = φ(a)`
— a constant stretch of running products is constant at every prefix. (`greenJ` +
`IsJTrivial`.) -/
theorem prefix_squeeze {L : Set (FreeMonoid α)} (h : IsJTrivial (SyntacticMonoid L))
    (a b₁ b₂ : FreeMonoid α)
    (hyp : syntacticMorphism L (a * b₁ * b₂) = syntacticMorphism L a) :
    syntacticMorphism L (a * b₁) = syntacticMorphism L a := by
  refine (h (syntacticMorphism L a) (syntacticMorphism L (a * b₁)) ⟨?_, ?_⟩).symm
  · exact ⟨1, syntacticMorphism L b₂, by rw [one_mul, ← map_mul, ← hyp, map_mul]⟩
  · exact ⟨1, syntacticMorphism L b₁, by rw [one_mul, ← map_mul]⟩

/-- The **skeleton** of a word w.r.t. `φ`: keep only the letters that *change* the running
`φ`-value (Klíma's "blue" letters). -/
noncomputable def reduceWord {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M) :
    M → List α → List α
  | _, [] => []
  | val, a :: rest =>
      if val * φ (FreeMonoid.of a) = val then reduceWord φ val rest
      else a :: reduceWord φ (val * φ (FreeMonoid.of a)) rest

/-- **Claim 1 core**: the skeleton preserves the `φ`-value (in every left context `val`):
`val · φ(skel) = val · φ(w)`. With `val = 1`: `φ(skel w) = φ(w)` (`skel w ∼_L w`). -/
theorem reduceWord_spec {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (val : M) (w : List α) :
    val * φ (FreeMonoid.ofList (reduceWord φ val w)) = val * φ (FreeMonoid.ofList w) := by
  induction w generalizing val with
  | nil => simp [reduceWord]
  | cons a rest ih =>
    rw [reduceWord]
    by_cases hfix : val * φ (FreeMonoid.of a) = val
    · rw [if_pos hfix, ih val, FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hfix]
    · rw [if_neg hfix, FreeMonoid.ofList_cons, map_mul, ← mul_assoc,
          ih (val * φ (FreeMonoid.of a)), mul_assoc, ← map_mul, ← FreeMonoid.ofList_cons]

/-- `r` is a subword of `u` all of whose *skipped* letters are value-fixers (starting from
left-context `val`): each skipped `a` satisfies `val·φ(a) = val` at that point. -/
inductive GoodSub {M : Type*} [Monoid M] (φ : FreeMonoid α →* M) : M → List α → List α → Prop
  | nil (val : M) : GoodSub φ val [] []
  | skip {val : M} {a : α} {u r : List α} :
      val * φ (FreeMonoid.of a) = val → GoodSub φ val r u → GoodSub φ val r (a :: u)
  | keep {val : M} {a : α} {u r : List α} :
      GoodSub φ (val * φ (FreeMonoid.of a)) r u → GoodSub φ val (a :: r) (a :: u)

/-- **Claim-1 kernel — deleting value-fixers preserves `φ`**: `GoodSub φ val r u ⟹
val·φ(r) = val·φ(u)`. The non-blue letters of `u` are value-fixers, so any subword of `u`
keeping all blue positions (deleting only non-blue) has the same `φ`-value (Claim 1). -/
theorem GoodSub.value {M : Type*} [Monoid M] {φ : FreeMonoid α →* M} {val : M} {r u : List α}
    (h : GoodSub φ val r u) :
    val * φ (FreeMonoid.ofList r) = val * φ (FreeMonoid.ofList u) := by
  induction h with
  | nil val => rfl
  | @skip val a u r hfix _ ih =>
    rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hfix, ih]
  | @keep val a u r _ ih =>
    rw [FreeMonoid.ofList_cons, FreeMonoid.ofList_cons, map_mul, map_mul,
        ← mul_assoc, ← mul_assoc, ih]

theorem GoodSub.value_one {M : Type*} [Monoid M] {φ : FreeMonoid α →* M} {r u : List α}
    (h : GoodSub φ 1 r u) : φ (FreeMonoid.ofList r) = φ (FreeMonoid.ofList u) := by
  simpa using h.value

/-- The skeleton `reduceWord φ val u` is a `GoodSub` witness (its skipped letters are exactly
the value-fixers). -/
theorem goodsub_reduceWord {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (val : M) (u : List α) : GoodSub φ val (reduceWord φ val u) u := by
  induction u generalizing val with
  | nil => exact GoodSub.nil val
  | cons a u' ih =>
    rw [reduceWord]
    by_cases hfix : val * φ (FreeMonoid.of a) = val
    · rw [if_pos hfix]; exact GoodSub.skip hfix (ih val)
    · rw [if_neg hfix]; exact GoodSub.keep (ih (val * φ (FreeMonoid.of a)))

/-- **Add back a value-fixer**: keeping a skipped value-fixer (it fixes `val`, so the running
value is unchanged) preserves `GoodSub`. Going from the minimal skeleton to any subword that
keeps all value-changers (e.g. `ū` = blue+red) is a sequence of such steps. -/
theorem GoodSub.keepFixer {M : Type*} [Monoid M] {φ : FreeMonoid α →* M} {val : M} {a : α}
    {r u : List α} (hfix : val * φ (FreeMonoid.of a) = val) (h : GoodSub φ val r u) :
    GoodSub φ val (a :: r) (a :: u) := GoodSub.keep (by rwa [hfix])

/-- The skeleton of a concatenation splits: process `l₁`, then `l₂` from the value reached. -/
theorem reduceWord_append {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (val : M) (l₁ l₂ : List α) :
    reduceWord φ val (l₁ ++ l₂)
    = reduceWord φ val l₁ ++ reduceWord φ (val * φ (FreeMonoid.ofList l₁)) l₂ := by
  induction l₁ generalizing val with
  | nil => simp [reduceWord]
  | cons a l₁' ih =>
    rw [List.cons_append, reduceWord]
    by_cases hfix : val * φ (FreeMonoid.of a) = val
    · rw [if_pos hfix, ih val, reduceWord, if_pos hfix,
          FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hfix]
    · rw [if_neg hfix, ih (val * φ (FreeMonoid.of a)), reduceWord, if_neg hfix,
          List.cons_append, FreeMonoid.ofList_cons, map_mul, ← mul_assoc]

/-- The skeleton of a prefix is a prefix of the skeleton (so the blue positions of a prefix
are an initial segment of the blue positions of the whole). -/
theorem reduceWord_take_prefix {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (u : List α) (n : ℕ) :
    (reduceWord φ 1 (u.take n)) <+: (reduceWord φ 1 u) := by
  conv_rhs => rw [← List.take_append_drop n u, reduceWord_append]
  exact List.prefix_append _ _

/-- The head of the skeleton is a value-changer (`reduceWord` keeps exactly the changers). -/
theorem reduceWord_head_changes {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (val : M) (u : List α) (d : α) (rest : List α) (h : reduceWord φ val u = d :: rest) :
    val * φ (FreeMonoid.of d) ≠ val := by
  induction u generalizing val with
  | nil => simp [reduceWord] at h
  | cons c u' ih =>
    rw [reduceWord] at h
    by_cases hc : val * φ (FreeMonoid.of c) = val
    · rw [if_pos hc] at h; exact ih val h
    · rw [if_neg hc] at h
      obtain ⟨rfl, _⟩ := List.cons.inj h
      exact hc

/-! ### Leftmost-occurrence machinery (toward Claim 2) -/

/-- Greedy match end position: number of letters of `w` consumed to greedily match all of
`s` (left to right). For `s ⊑ w` this is the *leftmost* end position. -/
def matchLen [DecidableEq α] : List α → List α → ℕ
  | [], _ => 0
  | _ :: _, [] => 0
  | a :: s, b :: w => if a = b then matchLen s w + 1 else matchLen (a :: s) w + 1
termination_by _ w => w.length

/-- **Greedy matching is leftmost**: if `s` is a subword of the first `n` letters of `w`,
then greedy matching finishes within `n` (`matchLen s w ≤ n`). This is the minimality that
makes the blue indices the *leftmost* occurrence of `u_left` (Claim 2: `i_t ≤ ℓ_t`). -/
theorem matchLen_le [DecidableEq α] (s w : List α) (n : ℕ) (h : s.Sublist (w.take n)) :
    matchLen s w ≤ n := by
  induction w generalizing s n with
  | nil =>
    cases s with
    | nil => simp [matchLen]
    | cons a s' => simp at h
  | cons b w' ih =>
    cases n with
    | zero =>
      simp only [List.take_zero] at h; rw [List.sublist_nil] at h; subst h; simp [matchLen]
    | succ n' =>
      rw [List.take_succ_cons] at h
      cases s with
      | nil => simp [matchLen]
      | cons a s' =>
        rw [matchLen]
        by_cases hab : a = b
        · subst hab; rw [if_pos rfl]
          have := ih s' n' (List.cons_sublist_cons.mp h); omega
        · rw [if_neg hab]
          have ha : (a :: s').Sublist (w'.take n') := by
            cases h with
            | cons _ h' => exact h'
            | cons₂ _ h' => exact absurd rfl hab
          have := ih (a :: s') n' ha; omega

/-- Start position of the *rightmost* greedy match of `s` in `w`. -/
def matchLenR [DecidableEq α] (s w : List α) : ℕ := w.length - matchLen s.reverse w.reverse

/-- **Greedy matching from the right is rightmost**: if `s ⊑ w.drop n` then the rightmost
match starts at `≥ n`. Dual of `matchLen_le` (via reversal); gives the red-side bound
`ℓ'_t ≤ j̄_t` in Claim 2. -/
theorem matchLenR_ge [DecidableEq α] (s w : List α) (n : ℕ) (hn : n ≤ w.length)
    (h : s.Sublist (w.drop n)) : n ≤ matchLenR s w := by
  have hrev : s.reverse.Sublist (w.reverse.take (w.length - n)) := by
    rw [← List.reverse_drop]; exact h.reverse
  have hle := matchLen_le s.reverse w.reverse (w.length - n) hrev
  have hlen : w.reverse.length = w.length := by simp
  unfold matchLenR; omega

/-- **Recovery (leftmost)**: if `s ⊑ w` then `s` already embeds in the greedy window
`w.take (matchLen s w)`. With `matchLen_le`, `matchLen s w` is exactly the leftmost end. -/
theorem matchLen_take_sublist [DecidableEq α] (s w : List α) (h : s.Sublist w) :
    s.Sublist (w.take (matchLen s w)) := by
  induction w generalizing s with
  | nil => rw [List.sublist_nil] at h; subst h; simp [matchLen]
  | cons b w' ih =>
    cases s with
    | nil => simp
    | cons a s' =>
      rw [matchLen]
      by_cases hab : a = b
      · subst hab
        rw [if_pos rfl, List.take_succ_cons]
        have hs' : s'.Sublist w' := by
          cases h with
          | cons _ h' => exact (List.sublist_cons_self _ _).trans h'
          | cons₂ _ h' => exact h'
        exact (ih s' hs').cons₂ a
      · rw [if_neg hab, List.take_succ_cons]
        have has : (a :: s').Sublist w' := by
          cases h with
          | cons _ h' => exact h'
          | cons₂ _ h' => exact absurd rfl hab
        exact (ih (a :: s') has).cons b

theorem matchLen_le_length [DecidableEq α] (s w : List α) : matchLen s w ≤ w.length := by
  induction w generalizing s with
  | nil => cases s <;> simp [matchLen]
  | cons b w' ih =>
    cases s with
    | nil => simp [matchLen]
    | cons a s' =>
      rw [matchLen]
      by_cases hab : a = b
      · rw [if_pos hab]; have := ih s'; simp only [List.length_cons]; omega
      · rw [if_neg hab]; have := ih (a :: s'); simp only [List.length_cons]; omega

theorem matchLen_nil [DecidableEq α] (s : List α) : matchLen s [] = 0 := by
  cases s <;> simp [matchLen]

/-- Greedy matching processes `s₁` then `s₂`: the engine for tracking the leftmost position
through the shuffle merge. -/
theorem matchLen_append [DecidableEq α] (s₁ s₂ w : List α) :
    matchLen (s₁ ++ s₂) w = matchLen s₁ w + matchLen s₂ (w.drop (matchLen s₁ w)) := by
  induction w generalizing s₁ with
  | nil => simp [matchLen_nil]
  | cons b w' ih =>
    cases s₁ with
    | nil => simp [matchLen]
    | cons a s₁' =>
      rw [List.cons_append, matchLen, matchLen]
      by_cases hab : a = b
      · rw [if_pos hab, if_pos hab, List.drop_succ_cons, ih s₁']; omega
      · rw [if_neg hab, if_neg hab, List.drop_succ_cons]
        have h := ih (a :: s₁'); rw [List.cons_append] at h; rw [h]; omega

/-- Greedy matching ignores letters past where `s` already fits. -/
theorem matchLen_append_right [DecidableEq α] (s w w' : List α) (h : s.Sublist w) :
    matchLen s (w ++ w') = matchLen s w := by
  induction w generalizing s with
  | nil => rw [List.sublist_nil] at h; subst h; simp [matchLen]
  | cons b w'' ih =>
    cases s with
    | nil => simp [matchLen]
    | cons a s' =>
      rw [List.cons_append, matchLen, matchLen]
      by_cases hab : a = b
      · rw [if_pos hab, if_pos hab]
        have hs' : s'.Sublist w'' := by
          cases h with
          | cons _ h' => exact (List.sublist_cons_self _ _).trans h'
          | cons₂ _ h' => exact h'
        rw [ih s' hs']
      · rw [if_neg hab, if_neg hab]
        have has : (a :: s').Sublist w'' := by
          cases h with
          | cons _ h' => exact h'
          | cons₂ _ h' => exact absurd rfl hab
        rw [ih (a :: s') has]

theorem matchLen_take_invariance [DecidableEq α] (s w : List α) (n : ℕ)
    (h : s.Sublist (w.take n)) : matchLen s w = matchLen s (w.take n) := by
  conv_lhs => rw [← List.take_append_drop n w]
  exact matchLen_append_right s (w.take n) (w.drop n) h

/-- **`matchLenR` localization** (red half of the global↔local bridge): the rightmost red
start in `u` is the rightmost start in the suffix `u.drop p`, shifted by `p`. -/
theorem matchLenR_localize [DecidableEq α] (s u : List α) (p : ℕ) (hp : p ≤ u.length)
    (h : s.Sublist (u.drop p)) : matchLenR s u = matchLenR s (u.drop p) + p := by
  have hrev : s.reverse.Sublist (u.reverse.take (u.length - p)) := by
    rw [← List.reverse_drop]; exact h.reverse
  have hinv : matchLen s.reverse u.reverse = matchLen s.reverse (u.reverse.take (u.length - p)) :=
    matchLen_take_invariance s.reverse u.reverse (u.length - p) hrev
  have hbound : matchLen s.reverse u.reverse ≤ u.length - p := by
    rw [hinv]; have := matchLen_le_length s.reverse (u.reverse.take (u.length - p))
    simp only [List.length_take, List.length_reverse] at this ⊢; omega
  unfold matchLenR
  rw [List.length_drop, List.reverse_drop, ← hinv]
  omega

/-- **Recovery (rightmost)**: `s ⊑ w` embeds in the suffix `w.drop (matchLenR s w)`. -/
theorem matchLenR_drop_sublist [DecidableEq α] (s w : List α) (h : s.Sublist w) :
    s.Sublist (w.drop (matchLenR s w)) := by
  have hr := (matchLen_take_sublist s.reverse w.reverse h.reverse).reverse
  rw [List.reverse_reverse] at hr
  have h1 : (w.drop (w.length - matchLen s.reverse w.reverse)).reverse
      = w.reverse.take (matchLen s.reverse w.reverse) := by
    rw [List.reverse_drop]; congr 1
    have := matchLen_le_length s.reverse w.reverse
    simp only [List.length_reverse] at this; omega
  rw [← h1, List.reverse_reverse] at hr
  exact hr

/-- **Order-determination (the `(i)/(ii)/(iii)` core)**: with `blue, red ⊑ u`, the test word
`blue ++ red` embeds in `u` iff the leftmost blue end is `≤` the rightmost red start —
exactly Klíma's `i_{r'} < j̄_{s'} ⟺ w_{r's'} ⊑ u`, via the two position bounds. -/
theorem append_sublist_iff_matchLen [DecidableEq α] (blue red u : List α)
    (hb : blue.Sublist u) (hr : red.Sublist u) :
    (blue ++ red).Sublist u ↔ matchLen blue u ≤ matchLenR red u := by
  constructor
  · intro h
    obtain ⟨u₁, u₂, hu, hb1, hr2⟩ := List.append_sublist_iff.mp h
    have hbtake : blue.Sublist (u.take u₁.length) := by rw [hu, List.take_left]; exact hb1
    have h1 : matchLen blue u ≤ u₁.length := matchLen_le blue u u₁.length hbtake
    have hrdrop : red.Sublist (u.drop u₁.length) := by rw [hu, List.drop_left]; exact hr2
    have hle : u₁.length ≤ u.length := by rw [hu, List.length_append]; omega
    have h2 : u₁.length ≤ matchLenR red u := matchLenR_ge red u u₁.length hle hrdrop
    omega
  · intro h
    have hbt := matchLen_take_sublist blue u hb
    have hrd := matchLenR_drop_sublist red u hr
    have hbt2 : blue.Sublist (u.take (matchLenR red u)) :=
      hbt.trans (List.take_sublist_take_left h)
    rw [← List.take_append_drop (matchLenR red u) u]
    exact hbt2.append hrd

/-- No skeleton ⇒ every letter fixes the value. -/
theorem reduceWord_nil_forward {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M) :
    ∀ (val : M) (w : List α), reduceWord φ val w = [] →
      ∀ c ∈ w, val * φ (FreeMonoid.of c) = val := by
  intro val w
  induction w generalizing val with
  | nil => intro _ c hc; simp at hc
  | cons c₀ w' ih =>
    intro h c hc
    rw [reduceWord] at h
    by_cases hc₀ : val * φ (FreeMonoid.of c₀) = val
    · rw [if_pos hc₀] at h
      rcases List.mem_cons.mp hc with rfl | hmem
      · exact hc₀
      · exact ih val h c hmem
    · rw [if_neg hc₀] at h; exact absurd h (by simp)

/-- **Sync / trailing-fixer.** After greedily matching the skeleton `reduceWord φ val u`
against `u`, every *remaining* letter fixes the final value `val·φ(u)`. So a value-changer
cannot appear after the skeleton's greedy match — this is the engine of the leftmost bound
`i_t ≤ ℓ_t` (a changer matched past the skeleton would contradict this). -/
theorem reduceWord_trailing_fix {M : Type*} [Monoid M] [DecidableEq M] [DecidableEq α]
    (φ : FreeMonoid α →* M) :
    ∀ (val : M) (u : List α) (c : α),
      c ∈ u.drop (matchLen (reduceWord φ val u) u) →
      val * φ (FreeMonoid.ofList u) * φ (FreeMonoid.of c) = val * φ (FreeMonoid.ofList u) := by
  intro val u
  induction u generalizing val with
  | nil => intro c hc; simp at hc
  | cons c₀ u' ih =>
    intro c hc
    have hval : val * φ (FreeMonoid.ofList (c₀ :: u'))
        = val * φ (FreeMonoid.of c₀) * φ (FreeMonoid.ofList u') := by
      rw [FreeMonoid.ofList_cons, map_mul, mul_assoc]
    by_cases hc₀ : val * φ (FreeMonoid.of c₀) = val
    · rw [reduceWord, if_pos hc₀] at hc
      cases hskel : reduceWord φ val u' with
      | nil =>
        rw [hskel] at hc; simp only [matchLen, List.drop_zero] at hc
        have hall := reduceWord_nil_forward φ val u' hskel
        have hu' : val * φ (FreeMonoid.ofList u') = val := by
          have hs := reduceWord_spec φ val u'
          rw [hskel] at hs; simp only [FreeMonoid.ofList_nil, map_one, mul_one] at hs
          exact hs.symm
        have hfix : val * φ (FreeMonoid.of c) = val := by
          rcases List.mem_cons.mp hc with rfl | hmem
          · exact hc₀
          · exact hall c hmem
        rw [hval, hc₀, hu', hfix]
      | cons d rest =>
        rw [hskel] at hc
        have hd : val * φ (FreeMonoid.of d) ≠ val := reduceWord_head_changes φ val u' d rest hskel
        have hdc₀ : d ≠ c₀ := fun h => hd (h ▸ hc₀)
        rw [matchLen, if_neg hdc₀, ← hskel, List.drop_succ_cons] at hc
        rw [hval, hc₀]; exact ih val c hc
    · rw [reduceWord, if_neg hc₀, matchLen, if_pos rfl, List.drop_succ_cons] at hc
      rw [hval]; exact ih (val * φ (FreeMonoid.of c₀)) c hc

/-- If `s ++ [a] ⊑ w` then `a` appears in the trailing region `w.drop (matchLen s w)`
(greedy is leftmost, so any embedding of the final `a` lands at or past the greedy end). -/
theorem matchLen_drop_mem [DecidableEq α] :
    ∀ (s w : List α) (a : α), (s ++ [a]).Sublist w → a ∈ w.drop (matchLen s w) := by
  intro s w
  induction w generalizing s with
  | nil => intro a h; simp at h
  | cons b w' ih =>
    intro a h
    cases s with
    | nil =>
      simp only [matchLen, List.drop_zero]
      exact List.singleton_sublist.mp h
    | cons s₀ s' =>
      rw [List.cons_append] at h
      by_cases hsb : s₀ = b
      · subst hsb
        rw [matchLen, if_pos rfl, List.drop_succ_cons]
        cases h with
        | cons _ h' => exact ih s' a ((List.sublist_cons_self _ _).trans h')
        | cons₂ _ h' => exact ih s' a h'
      · rw [matchLen, if_neg hsb, List.drop_succ_cons]
        cases h with
        | cons _ h' => exact ih (s₀ :: s') a h'
        | cons₂ _ h' => exact absurd rfl hsb

/-- **Leftmost bound** (Klíma's `i_t ≤ ℓ_t`): if the first `t` blue letters of `u` embed in
the prefix `u.take n`, then that prefix already contains `≥ t` value-changes. Equivalently,
the blue (value-change) positions are the *leftmost* occurrence of the blue word. Assembled
from `reduceWord_trailing_fix` (trailing letters fix the value), `matchLen_drop_mem` (an extra
changer must land in that trailing region), and `reduceWord_head_changes` (but it changes the
value) — the contradiction. -/
theorem leftmost_bound {M : Type*} [Monoid M] [DecidableEq M] [DecidableEq α]
    (φ : FreeMonoid α →* M) (u : List α) (n t : ℕ)
    (ht : t ≤ (reduceWord φ 1 u).length)
    (hsub : ((reduceWord φ 1 u).take t).Sublist (u.take n)) :
    t ≤ (reduceWord φ 1 (u.take n)).length := by
  by_contra hlt
  rw [not_le] at hlt
  have hsplit : reduceWord φ 1 u
      = reduceWord φ 1 (u.take n)
        ++ reduceWord φ (1 * φ (FreeMonoid.ofList (u.take n))) (u.drop n) := by
    conv_lhs => rw [← List.take_append_drop n u]
    exact reduceWord_append φ 1 (u.take n) (u.drop n)
  have hlen : (reduceWord φ 1 u).length
      = (reduceWord φ 1 (u.take n)).length
        + (reduceWord φ (1 * φ (FreeMonoid.ofList (u.take n))) (u.drop n)).length := by
    rw [hsplit, List.length_append]
  have hrest_ne : reduceWord φ (1 * φ (FreeMonoid.ofList (u.take n))) (u.drop n) ≠ [] := by
    intro hnil; rw [hnil, List.length_nil, Nat.add_zero] at hlen; omega
  obtain ⟨a, rest', ha⟩ := List.exists_cons_of_ne_nil hrest_ne
  have hchg : (1 * φ (FreeMonoid.ofList (u.take n))) * φ (FreeMonoid.of a)
      ≠ 1 * φ (FreeMonoid.ofList (u.take n)) :=
    reduceWord_head_changes φ _ (u.drop n) a rest' ha
  have htake : (reduceWord φ 1 u).take ((reduceWord φ 1 (u.take n)).length + 1)
      = reduceWord φ 1 (u.take n) ++ [a] := by
    rw [hsplit, ha, List.take_length_add_append]; simp
  have hsubp : (reduceWord φ 1 (u.take n) ++ [a]).Sublist (u.take n) := by
    rw [← htake]
    exact (List.take_sublist_take_left (by omega)).trans hsub
  have hmem := matchLen_drop_mem _ (u.take n) a hsubp
  exact hchg (reduceWord_trailing_fix φ 1 (u.take n) a hmem)

/-! ### Red/dual side (rightmost occurrence, via the opposite monoid + reversal) -/

/-- Read letters into `Mᵐᵒᵖ`, so prefixes of `u.reverse` track the *suffix* values of `u`. -/
noncomputable def opPhi {M : Type*} [Monoid M] (φ : FreeMonoid α →* M) : FreeMonoid α →* Mᵐᵒᵖ :=
  FreeMonoid.lift (fun a => MulOpposite.op (φ (FreeMonoid.of a)))

/-- The **red skeleton** of `u`: read `u` right-to-left into `Mᵐᵒᵖ` and keep the
suffix-value changers (the red letters, in right-to-left order). -/
noncomputable def redSkel {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (u : List α) : List α :=
  reduceWord (opPhi φ) 1 u.reverse

/-- **Rightmost bound** (red dual of `leftmost_bound`, Klíma's `ℓ'_t ≤ j̄_t`): if the last `t`
red letters of `u` embed in the suffix `u.drop m`, that suffix already has `≥ t` suffix-value
changes. Obtained *for free* from `leftmost_bound` via the opposite monoid `Mᵐᵒᵖ` and word
reversal — the same induction, no new proof. -/
theorem rightmost_bound {M : Type*} [Monoid M] [DecidableEq M] [DecidableEq α]
    (φ : FreeMonoid α →* M) (u : List α) (m t : ℕ)
    (ht : t ≤ (redSkel φ u).length)
    (hsub : ((redSkel φ u).take t).Sublist ((u.drop m).reverse)) :
    t ≤ (redSkel φ (u.drop m)).length := by
  have hrev : (u.drop m).reverse = u.reverse.take (u.length - m) := List.reverse_drop
  unfold redSkel at *
  rw [hrev] at hsub ⊢
  exact leftmost_bound (opPhi φ) u.reverse (u.length - m) t ht hsub

/-! ### Subword foundations for the blue/red words (toward the shuffle) -/

/-- A `GoodSub` witness is a sublist. -/
theorem GoodSub.sublist {M : Type*} [Monoid M] {φ : FreeMonoid α →* M} {val : M} {r u : List α}
    (h : GoodSub φ val r u) : r.Sublist u := by
  induction h with
  | nil => exact List.Sublist.refl []
  | skip _ _ ih => exact ih.cons _
  | keep _ ih => exact ih.cons₂ _

/-- The blue word `u_left = reduceWord φ 1 u` is a subword of `u`. -/
theorem reduceWord_sublist {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (u : List α) : (reduceWord φ 1 u).Sublist u :=
  (goodsub_reduceWord φ 1 u).sublist

/-- The red skeleton is a subword of `u.reverse`. -/
theorem redSkel_sublist {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (u : List α) : (redSkel φ u).Sublist u.reverse :=
  (goodsub_reduceWord (opPhi φ) 1 u.reverse).sublist

/-- The red word `(redSkel φ u).reverse` (red letters in forward order) is a subword of `u`. -/
theorem redWord_sublist {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (u : List α) : ((redSkel φ u).reverse).Sublist u := by
  have h := (redSkel_sublist φ u).reverse
  simpa using h

/-- **`opPhi` reads a word as `φ` of its reverse, opposed.** `opPhi φ (ofList w) =
op (φ (ofList w.reverse))`. The bridge between the forward (`φ`) and dual (`Mᵐᵒᵖ`) value sides;
this is what turns `bridge_v` into `bridge_u` in the opposite monoid. -/
theorem opPhi_ofList {M : Type*} [Monoid M] (φ : FreeMonoid α →* M) (w : List α) :
    opPhi φ (FreeMonoid.ofList w) = MulOpposite.op (φ (FreeMonoid.ofList w.reverse)) := by
  induction w with
  | nil => simp [opPhi]
  | cons a w' ih =>
    rw [FreeMonoid.ofList_cons, map_mul, ih, List.reverse_cons, FreeMonoid.ofList_append, map_mul]
    simp [opPhi]

/-! ### Explicit position lists (toward the bridge, step 3)

The bridge `shuffleWord = maskKeep` needs the blue/red letters' actual positions in `u`.
`gpos s w k` is the greedy *leftmost* embedding of `s` into `w`, as a strictly increasing
list of positions (offset by `k`). Blue positions `= gpos u_left u 0`; red positions come by
reversal. The `(i)/(ii)/(iii)` order argument is then a comparison of these lists. -/

/-- Greedy leftmost match positions of `s` in `w`, offset by `k`. -/
def gpos [DecidableEq α] : List α → List α → ℕ → List ℕ
  | [], _, _ => []
  | _ :: _, [], _ => []
  | a :: s, b :: w, k => if a = b then k :: gpos s w (k + 1) else gpos (a :: s) w (k + 1)
  termination_by _ w _ => w.length

/-- Every matched position is `≥` the starting offset. -/
theorem gpos_ge [DecidableEq α] (s w : List α) (k : ℕ) : ∀ p ∈ gpos s w k, k ≤ p := by
  induction w generalizing s k with
  | nil => cases s <;> intro p hp <;> simp [gpos] at hp
  | cons b w' ih =>
    cases s with
    | nil => intro p hp; simp [gpos] at hp
    | cons a s' =>
      intro p hp
      rw [gpos] at hp
      by_cases hab : a = b
      · rw [if_pos hab] at hp
        rcases List.mem_cons.mp hp with hpk | hmem
        · omega
        · have := ih s' (k + 1) p hmem; omega
      · rw [if_neg hab] at hp
        have := ih (a :: s') (k + 1) p hp; omega

/-- The matched positions are strictly increasing. -/
theorem gpos_sorted [DecidableEq α] (s w : List α) (k : ℕ) :
    List.Pairwise (· < ·) (gpos s w k) := by
  induction w generalizing s k with
  | nil => cases s <;> simp [gpos]
  | cons b w' ih =>
    cases s with
    | nil => simp [gpos]
    | cons a s' =>
      rw [gpos]
      by_cases hab : a = b
      · rw [if_pos hab]
        refine List.Pairwise.cons ?_ (ih s' (k + 1))
        intro p hp; have := gpos_ge s' w' (k + 1) p hp; omega
      · rw [if_neg hab]; exact ih (a :: s') (k + 1)

/-! ### The shuffle merge (toward Claim 2)

The shuffle `ū` is a merge of the blue word `u_left` and the red word `v_right`, interleaved
by their positions in `u`. We represent the merge by an `Ordering`-comparator `cmp i j`
(is the `i`-th blue position `<`/`=`/`>` the `j`-th red position). Then:
* **merge-determination is free** — `mergeO` is a *function* of `cmp`, so once we show the
  comparator is the same for `u` and `v` (because each comparison is a length-`≤2m−2` subword
  test, and `u ∼_{2m−2} v`), we get `ū = v̄` immediately;
* the remaining work is (a) the comparator ↔ subword-test lemma (uses `leftmost_bound` +
  `rightmost_bound`), and (b) Claim-1 closure `φ(ū) = φ(u)` via `u_left ⊑ ū ⊑ u`. -/

/-- Merge of a blue word `x` and red word `y`, driven by a comparator `cmp i j` (is the `i`-th
blue position `lt`/`eq`/`gt` the `j`-th red position). `eq` = a shared position (the letters
coincide), emitted once. -/
def mergeO (cmp : ℕ → ℕ → Ordering) : List α → List α → ℕ → ℕ → List α
  | [], y, _, _ => y
  | a :: x, [], _, _ => a :: x
  | a :: x, b :: y, i, j =>
    match cmp i j with
    | .lt => a :: mergeO cmp x (b :: y) (i + 1) j
    | .gt => b :: mergeO cmp (a :: x) y i (j + 1)
    | .eq => a :: mergeO cmp x y (i + 1) (j + 1)
  termination_by x y _ _ => x.length + y.length

/-- The blue word `x` always embeds in the merge (so `ū` contains all blue letters — the
hypothesis Claim 1 needs). -/
theorem mergeO_left_sublist (cmp : ℕ → ℕ → Ordering) :
    ∀ (x y : List α) (i j : ℕ), x.Sublist (mergeO cmp x y i j) := by
  intro x y i j
  fun_induction mergeO cmp x y i j with
  | case1 y i j => exact List.nil_sublist _
  | case2 a x i j => exact List.Sublist.refl _
  | case3 a x b y i j hlt ih => exact ih.cons₂ a
  | case4 a x b y i j hgt ih => exact ih.cons b
  | case5 a x b y i j heq ih => exact ih.cons₂ a

/-- **Comparator congruence for `mergeO`.** Two comparators agreeing on the *consulted rectangle*
`[i, i+|x|) × [j, j+|y|)` produce the same merge. (`mergeO` only inspects `cmp p q` while both
lists are nonempty, so agreement outside that rectangle is irrelevant — this is what lets the
position-union comparator `pcmp` transfer under `∼ₖ`, where it agrees only *in range*.) -/
theorem mergeO_congr (cmp1 cmp2 : ℕ → ℕ → Ordering) :
    ∀ (x y : List α) (i j : ℕ),
      (∀ p q, i ≤ p → p < i + x.length → j ≤ q → q < j + y.length → cmp1 p q = cmp2 p q) →
      mergeO cmp1 x y i j = mergeO cmp2 x y i j := by
  intro x y i j h
  fun_induction mergeO cmp1 x y i j with
  | case1 y i j => simp [mergeO]
  | case2 a x i j => simp [mergeO]
  | case3 a x b y i j hlt ih =>
    have hag : cmp1 i j = cmp2 i j :=
      h i j (le_refl _) (by simp only [List.length_cons]; omega) (le_refl _)
        (by simp only [List.length_cons]; omega)
    have hc2 : cmp2 i j = Ordering.lt := hag ▸ hlt
    have ih' := ih (fun p q hp1 hp2 hq1 hq2 =>
      h p q (by omega) (by simp only [List.length_cons] at *; omega) hq1 hq2)
    rw [show mergeO cmp2 (a :: x) (b :: y) i j = a :: mergeO cmp2 x (b :: y) (i + 1) j from by
      rw [mergeO, hc2], ih']
  | case4 a x b y i j hgt ih =>
    have hag : cmp1 i j = cmp2 i j :=
      h i j (le_refl _) (by simp only [List.length_cons]; omega) (le_refl _)
        (by simp only [List.length_cons]; omega)
    have hc2 : cmp2 i j = Ordering.gt := hag ▸ hgt
    have ih' := ih (fun p q hp1 hp2 hq1 hq2 =>
      h p q hp1 hp2 (by omega) (by simp only [List.length_cons] at *; omega))
    rw [show mergeO cmp2 (a :: x) (b :: y) i j = b :: mergeO cmp2 (a :: x) y i (j + 1) from by
      rw [mergeO, hc2], ih']
  | case5 a x b y i j heq ih =>
    have hag : cmp1 i j = cmp2 i j :=
      h i j (le_refl _) (by simp only [List.length_cons]; omega) (le_refl _)
        (by simp only [List.length_cons]; omega)
    have hc2 : cmp2 i j = Ordering.eq := hag ▸ heq
    have ih' := ih (fun p q hp1 hp2 hq1 hq2 =>
      h p q (by omega) (by simp only [List.length_cons] at *; omega) (by omega)
        (by simp only [List.length_cons] at *; omega))
    rw [show mergeO cmp2 (a :: x) (b :: y) i j = a :: mergeO cmp2 x y (i + 1) (j + 1) from by
      rw [mergeO, hc2], ih']

/-- The blue/red comparator from Klíma's subword tests: is the `i`-th blue position `<`/`=`/`>`
the `j`-th red position?  `lt` ⟺ `(x.take (i+1)) ++ (y.drop j) ⊑ w` (Klíma's `w_{r's'}`);
`eq` ⟺ that fails but the shared-position variant (drop the current red) embeds; else `gt`. -/
def brCmp [DecidableEq α] (x y w : List α) (i j : ℕ) : Ordering :=
  if (x.take (i + 1) ++ y.drop j).Sublist w then Ordering.lt
  else if (x.take (i + 1) ++ y.drop (j + 1)).Sublist w then Ordering.eq
  else Ordering.gt

/-- `ū` = the shuffle of blue word `x` and red word `y` as they sit in `w`. -/
def shuffleWord [DecidableEq α] (x y w : List α) : List α := mergeO (brCmp x y w) x y 0 0

/-- The comparator is determined by length-`≤k` subword tests, so it agrees on `∼_k`-equivalent
words once the blue+red lengths fit in `k`. -/
theorem brCmp_eq [DecidableEq α] (x y u v : List α) (k : ℕ) (hk : x.length + y.length ≤ k)
    (hsim : ∀ z : List α, z.length ≤ k → (z.Sublist u ↔ z.Sublist v)) :
    brCmp x y u = brCmp x y v := by
  funext i j
  have hlen : ∀ d : ℕ, (x.take (i + 1) ++ y.drop d).length ≤ k := by
    intro d; rw [List.length_append, List.length_take, List.length_drop]; omega
  unfold brCmp
  simp only [hsim _ (hlen j), hsim _ (hlen (j + 1))]

/-- **Shuffle equality** (Klíma's Claim 2, combinatorial core) `ū = v̄`: the blue/red shuffle is
the same word in `u` and `v`. Because `mergeO` is a *function* of the comparator and the
comparator agrees under `∼_k` (`hsim`, given the length budget `hk`), this is immediate — the
design front-loaded all the work into `brCmp`/`mergeO`. -/
theorem shuffleWord_eq [DecidableEq α] (x y u v : List α) (k : ℕ) (hk : x.length + y.length ≤ k)
    (hsim : ∀ z : List α, z.length ≤ k → (z.Sublist u ↔ z.Sublist v)) :
    shuffleWord x y u = shuffleWord x y v := by
  unfold shuffleWord; rw [brCmp_eq x y u v k hk hsim]

/-- `brCmp = lt` ⟺ the blue/red test word embeds in `u` (just unfolding `brCmp`). -/
theorem brCmp_lt_iff [DecidableEq α] (x y u : List α) (i j : ℕ) :
    brCmp x y u i j = Ordering.lt ↔ (x.take (i + 1) ++ y.drop j).Sublist u := by
  unfold brCmp
  by_cases h1 : (x.take (i + 1) ++ y.drop j).Sublist u
  · simp [h1]
  · by_cases h2 : (x.take (i + 1) ++ y.drop (j + 1)).Sublist u <;> simp [h1, h2]

/-- **`brCmp` identified with the position comparison**: `brCmp = lt` ⟺ leftmost blue end
`≤` rightmost red start — `brCmp` is a faithful encoding of the `matchLen` order. -/
theorem brCmp_lt_iff_matchLen [DecidableEq α] (x y u : List α) (i j : ℕ)
    (hb : (x.take (i + 1)).Sublist u) (hr : (y.drop j).Sublist u) :
    brCmp x y u i j = Ordering.lt ↔ matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop j) u := by
  rw [brCmp_lt_iff, append_sublist_iff_matchLen _ _ _ hb hr]

/-- `brCmp = eq` ⟺ the test word *with* the next red fails but *without* it succeeds. -/
theorem brCmp_eq_iff [DecidableEq α] (x y u : List α) (i j : ℕ) :
    brCmp x y u i j = Ordering.eq ↔
      ¬ (x.take (i + 1) ++ y.drop j).Sublist u ∧ (x.take (i + 1) ++ y.drop (j + 1)).Sublist u := by
  unfold brCmp
  by_cases h1 : (x.take (i + 1) ++ y.drop j).Sublist u
  · simp [h1]
  · by_cases h2 : (x.take (i + 1) ++ y.drop (j + 1)).Sublist u <;> simp [h1, h2]

/-- **`brCmp = eq` as a position sandwich**: the rightmost `j`-red start is strictly left of the
leftmost `(i+1)`-blue end, which is in turn `≤` the rightmost `(j+1)`-red start. The dual of
`brCmp_lt_iff_matchLen`. Coincidence (`bridge_v`'s `eq` case) is then exactly the extra inequality
`matchLen (x.take (i+1)) u ≤ matchLenR (y.drop j) u + 1`, forcing the red position `=` blue. -/
theorem brCmp_eq_iff_matchLen [DecidableEq α] (x y u : List α) (i j : ℕ)
    (hb : (x.take (i + 1)).Sublist u) (hr0 : (y.drop j).Sublist u)
    (hr1 : (y.drop (j + 1)).Sublist u) :
    brCmp x y u i j = Ordering.eq ↔
      (matchLenR (y.drop j) u < matchLen (x.take (i + 1)) u ∧
       matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop (j + 1)) u) := by
  rw [brCmp_eq_iff, append_sublist_iff_matchLen _ _ _ hb hr0,
      append_sublist_iff_matchLen _ _ _ hb hr1]
  constructor
  · intro ⟨h1, h2⟩; exact ⟨by omega, h2⟩
  · intro ⟨h1, h2⟩; exact ⟨by omega, h2⟩

/-! ### Merge-embedding machinery (the two-cursor merge induction)

Invariant at merge state `(i,j,p)`: blue cursor `matchLen (x.take i) u ≤ p`, both remainders
embed in `u.drop p`, the next blue position is `> p` and the next red position is `≥ p`. Each
step emits the position-minimal letter (`lt`→blue, `gt`→red) and advances `p` to just past it;
`emb_step` splices it in, the `matchLen` laws advance the cursors. -/

/-- Splice one letter at the front: if `a` sits in the window `u[p:m]` and `W` embeds in
`u.drop m`, then `a :: W` embeds in `u.drop p`. -/
theorem emb_step {α : Type*} (a : α) (W u : List α) (p m : ℕ) (hpm : p ≤ m)
    (ha : [a].Sublist ((u.drop p).take (m - p))) (hW : W.Sublist (u.drop m)) :
    (a :: W).Sublist (u.drop p) := by
  have hdrop : (u.drop p).drop (m - p) = u.drop m := by rw [List.drop_drop]; congr 1; omega
  have key : ([a] ++ W).Sublist ((u.drop p).take (m - p) ++ u.drop m) := ha.append hW
  rw [← hdrop, List.take_append_drop] at key
  simpa using key

/-- Single-letter greedy match commutes with dropping a prefix shorter than the match. -/
theorem matchLen_single_drop {α : Type*} [DecidableEq α] (a : α) (w : List α) (d : ℕ)
    (hd : d < matchLen [a] w) : matchLen [a] (w.drop d) = matchLen [a] w - d := by
  induction w generalizing d with
  | nil => simp [matchLen] at hd
  | cons b w' ih =>
    by_cases hab : a = b
    · have hz : d = 0 := by rw [matchLen, if_pos hab] at hd; simp [matchLen] at hd; omega
      subst hz; simp
    · have hmb : matchLen [a] (b :: w') = matchLen [a] w' + 1 := by rw [matchLen, if_neg hab]
      rw [hmb] at hd ⊢
      cases d with
      | zero => simp [hmb]
      | succ d' => rw [List.drop_succ_cons, ih d' (by omega)]; omega

/-- After matching the head `a` greedily (leftmost), the tail still embeds in the suffix. -/
theorem sublist_drop_single {α : Type*} [DecidableEq α] (a : α) (l w : List α)
    (h : (a :: l).Sublist w) : l.Sublist (w.drop (matchLen [a] w)) := by
  induction w generalizing l with
  | nil => simp at h
  | cons b w' ih =>
    rw [matchLen]
    by_cases hab : a = b
    · rw [if_pos hab]
      simp only [matchLen, Nat.zero_add, List.drop_succ_cons, List.drop_zero]
      cases h with
      | cons _ h' => exact (List.sublist_cons_self _ _).trans h'
      | cons₂ _ h' => exact h'
    · rw [if_neg hab, List.drop_succ_cons]
      have hw' : (a :: l).Sublist w' := by
        cases h with
        | cons _ h' => exact h'
        | cons₂ _ h' => exact absurd rfl hab
      exact ih l hw'

/-- Greedy matching `s` leaves the rest `t` embeddable in the suffix. -/
theorem matchLen_append_sublist {α : Type*} [DecidableEq α] (s t w : List α)
    (h : (s ++ t).Sublist w) : t.Sublist (w.drop (matchLen s w)) := by
  induction s generalizing w with
  | nil => simpa [matchLen] using h
  | cons a s' ih =>
    rw [List.cons_append] at h
    have h1 := sublist_drop_single a (s' ++ t) w h
    have h2 := ih _ h1
    rwa [List.drop_drop, ← matchLen_append] at h2

theorem matchLen_single_pos {α : Type*} [DecidableEq α] (b : α) (w : List α) (hw : w ≠ []) :
    1 ≤ matchLen [b] w := by
  cases w with
  | nil => exact absurd rfl hw
  | cons c w' => rw [matchLen]; split <;> omega

/-- Appending a matchable letter strictly increases the greedy match length. -/
theorem matchLen_append_strict {α : Type*} [DecidableEq α] (s : List α) (b : α) (w : List α)
    (h : (s ++ [b]).Sublist w) : matchLen s w + 1 ≤ matchLen (s ++ [b]) w := by
  rw [matchLen_append]
  have hb : [b].Sublist (w.drop (matchLen s w)) := matchLen_append_sublist s [b] w h
  have hne : w.drop (matchLen s w) ≠ [] := by
    intro he; rw [he] at hb; exact absurd hb (by simp)
  have := matchLen_single_pos b (w.drop (matchLen s w)) hne
  omega

/-- **Red monotonicity**: a longer red word starts strictly further left (rightmost match). -/
theorem matchLenR_cons_lt {α : Type*} [DecidableEq α] (b : α) (ys u : List α)
    (h : (b :: ys).Sublist u) : matchLenR (b :: ys) u < matchLenR ys u := by
  have hrev : (ys.reverse ++ [b]).Sublist u.reverse := by have := h.reverse; simpa using this
  have hstrict : matchLen ys.reverse u.reverse + 1 ≤ matchLen (ys.reverse ++ [b]) u.reverse :=
    matchLen_append_strict ys.reverse b u.reverse hrev
  have hle : matchLen (ys.reverse ++ [b]) u.reverse ≤ u.length := by
    have := matchLen_le_length (ys.reverse ++ [b]) u.reverse; simpa using this
  unfold matchLenR
  have heq : ((b :: ys).reverse) = ys.reverse ++ [b] := by simp
  rw [heq]; omega

/-- Local blue position from the cursor: with cursor `pB ≤ p` and the next blue still ahead,
the local single-letter match length is `m - p`. -/
theorem blue_advance {α : Type*} [DecidableEq α] (a : α) (u : List α) (pB p : ℕ) (hpB : pB ≤ p)
    (hp : p < pB + matchLen [a] (u.drop pB)) :
    matchLen [a] (u.drop p) = (pB + matchLen [a] (u.drop pB)) - p := by
  have hdd : u.drop p = (u.drop pB).drop (p - pB) := by rw [List.drop_drop]; congr 1; omega
  rw [hdd, matchLen_single_drop a (u.drop pB) (p - pB) (by omega)]
  omega

/-- The next blue's greedy end is strictly beyond the current one. -/
theorem matchLen_take_strict_mono {α : Type*} [DecidableEq α] (x u : List α) (hx : x.Sublist u)
    (k : ℕ) (hk : k < x.length) :
    matchLen (x.take k) u < matchLen (x.take (k + 1)) u := by
  have hne : x.drop k ≠ [] := by rw [Ne, List.drop_eq_nil_iff]; omega
  obtain ⟨c, xs, hc⟩ := List.exists_cons_of_ne_nil hne
  have hsplit : x.take (k + 1) = x.take k ++ [c] := by rw [List.take_add, hc]; rfl
  rw [hsplit]
  have hsub : (x.take k ++ [c]).Sublist u := by rw [← hsplit]; exact (List.take_sublist _ _).trans hx
  have := matchLen_append_strict (x.take k) c u hsub
  omega

/-- Single greedy match lands the letter at position `matchLen - 1`. -/
theorem matchLen_single_get? {α : Type*} [DecidableEq α] (c : α) (w : List α) (h : [c].Sublist w) :
    w[matchLen [c] w - 1]? = some c := by
  induction w with
  | nil => simp at h
  | cons d w' ih =>
    by_cases hcd : c = d
    · subst hcd
      have h1 : matchLen [c] (c :: w') = 1 := by simp [matchLen]
      rw [h1]; simp
    · have hsub : [c].Sublist w' := by
        cases h with
        | cons _ h' => exact h'
        | cons₂ _ h' => exact absurd rfl hcd
      have hpos : 1 ≤ matchLen [c] w' := matchLen_single_pos c w' (by rintro rfl; simp at hsub)
      have h1 : matchLen [c] (d :: w') = matchLen [c] w' + 1 := by rw [matchLen, if_neg hcd]
      rw [h1, Nat.add_sub_cancel, show matchLen [c] w' = (matchLen [c] w' - 1) + 1 from by omega,
          List.getElem?_cons_succ]
      exact ih hsub

/-- The appended letter lands at the end of the greedy match. -/
theorem matchLen_getElem_last {α : Type*} [DecidableEq α] (s : List α) (c : α) (w : List α)
    (h : (s ++ [c]).Sublist w) : w[matchLen (s ++ [c]) w - 1]? = some c := by
  have hsub : [c].Sublist (w.drop (matchLen s w)) := matchLen_append_sublist s [c] w h
  have hg := matchLen_single_get? c (w.drop (matchLen s w)) hsub
  rw [List.getElem?_drop] at hg
  have hpos : 1 ≤ matchLen [c] (w.drop (matchLen s w)) :=
    matchLen_single_pos c _ (by rintro he; rw [he] at hsub; simp at hsub)
  rw [matchLen_append,
      show matchLen s w + matchLen [c] (w.drop (matchLen s w)) - 1
        = matchLen s w + (matchLen [c] (w.drop (matchLen s w)) - 1) from by omega]
  exact hg

/-- **Rightmost pinning**: the red head sits exactly at its rightmost start `matchLenR`. -/
theorem matchLenR_get? {α : Type*} [DecidableEq α] (b : α) (ys u : List α)
    (h : (b :: ys).Sublist u) : u[matchLenR (b :: ys) u]? = some b := by
  have hrev : (ys.reverse ++ [b]).Sublist u.reverse := by have := h.reverse; simpa using this
  have hlast := matchLen_getElem_last ys.reverse b u.reverse hrev
  set M := matchLen (ys.reverse ++ [b]) u.reverse with hM
  have hMpos : 1 ≤ M := by
    rw [hM]; have := matchLen_single_pos b (u.reverse.drop (matchLen ys.reverse u.reverse))
      (by intro he; have := matchLen_append_sublist ys.reverse [b] u.reverse hrev
          rw [he] at this; simp at this)
    rw [matchLen_append]; omega
  have hMle : M ≤ u.length := by
    rw [hM]; have := matchLen_le_length (ys.reverse ++ [b]) u.reverse; simpa using this
  have hmr : matchLenR (b :: ys) u = u.length - M := by unfold matchLenR; rw [List.reverse_cons, ← hM]
  rw [List.getElem?_reverse (by omega : M - 1 < u.length)] at hlast
  rw [hmr, show u.length - M = u.length - 1 - (M - 1) from by omega]
  exact hlast

/-- The greedy single match of the red head is bounded by its rightmost position. -/
theorem matchLen_single_le_matchLenR {α : Type*} [DecidableEq α] (b : α) (ys u : List α) (p : ℕ)
    (h : (b :: ys).Sublist u) (hp : p ≤ matchLenR (b :: ys) u) :
    matchLen [b] (u.drop p) ≤ matchLenR (b :: ys) u + 1 - p := by
  set q := matchLenR (b :: ys) u with hq
  have hbq : u[q]? = some b := matchLenR_get? b ys u h
  have hbq' : (u.drop p)[q - p]? = some b := by
    rw [List.getElem?_drop, Nat.add_sub_cancel' hp]; exact hbq
  have hmem : b ∈ (u.drop p).take (q + 1 - p) := by
    have h2 : ((u.drop p).take (q + 1 - p))[q - p]? = some b := by
      rw [List.getElem?_take_of_lt (by omega)]; exact hbq'
    exact List.mem_of_getElem? h2
  exact matchLen_le [b] (u.drop p) (q + 1 - p) (List.singleton_sublist.mpr hmem)

/-- **`shuffleWord ⊑ u`** — the two-cursor merge induction. Blue letters are placed at their
leftmost (value) positions, red letters at their rightmost; the order-determination keeps the
merge consistent. -/
theorem merge_sub {α : Type*} [DecidableEq α] (x y u : List α)
    (hx : x.Sublist u) (hy : y.Sublist u) :
    ∀ (N i j p : ℕ), (x.length - i) + (y.length - j) ≤ N →
      matchLen (x.take i) u ≤ p →
      (x.drop i).Sublist (u.drop p) → (y.drop j).Sublist (u.drop p) →
      (i < x.length → p < matchLen (x.take (i + 1)) u) →
      (j < y.length → p ≤ matchLenR (y.drop j) u) →
      (mergeO (brCmp x y u) (x.drop i) (y.drop j) i j).Sublist (u.drop p) := by
  intro N
  induction N with
  | zero =>
    intro i j p hN _ _ _ _ _
    rw [List.drop_eq_nil_of_le (by omega : x.length ≤ i),
        List.drop_eq_nil_of_le (by omega : y.length ≤ j), mergeO]
    exact List.nil_sublist _
  | succ N ih =>
    intro i j p hN hcur hxr hyr hxnext hynext
    rcases hxi : x.drop i with _ | ⟨a, xs⟩
    · rw [mergeO]; exact hyr
    · rcases hyj : y.drop j with _ | ⟨b, ys⟩
      · rw [mergeO, ← hxi]; exact hxr
      · have hilt : i < x.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hxi; exact absurd hxi (by simp)
        have hjlt : j < y.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hyj; exact absurd hyj (by simp)
        have hxs_eq : x.drop (i + 1) = xs := by rw [← List.tail_drop, hxi, List.tail_cons]
        rw [mergeO]
        cases hbr : brCmp x y u i j with
        | lt =>
          have hxsplit : x.take (i + 1) = x.take i ++ [a] := by rw [List.take_add, hxi]; rfl
          have hm_eq : matchLen (x.take (i + 1)) u
              = matchLen (x.take i) u + matchLen [a] (u.drop (matchLen (x.take i) u)) := by
            rw [hxsplit, matchLen_append]
          have hpm : p < matchLen (x.take (i + 1)) u := hxnext hilt
          have hba : matchLen [a] (u.drop p) = matchLen (x.take (i + 1)) u - p := by
            rw [hm_eq] at hpm ⊢; exact blue_advance a u (matchLen (x.take i) u) p hcur hpm
          have hxr' : (a :: xs).Sublist (u.drop p) := hxi ▸ hxr
          have ha_in : [a].Sublist (u.drop p) :=
            List.singleton_sublist.mpr (hxr'.subset (by simp))
          have ha : [a].Sublist ((u.drop p).take (matchLen (x.take (i + 1)) u - p)) := by
            rw [← hba]; exact matchLen_take_sublist [a] (u.drop p) ha_in
          have hxs_drop : xs.Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have := sublist_drop_single a xs (u.drop p) hxr'
            rwa [List.drop_drop, hba, Nat.add_sub_cancel' (by omega : p ≤ matchLen (x.take (i+1)) u)] at this
          have hx_take_sub : (x.take (i + 1)).Sublist u := (List.take_sublist _ _).trans hx
          have hy_drop_sub : (y.drop j).Sublist u := (List.drop_sublist _ _).trans hy
          have hlt_le : matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop j) u :=
            (brCmp_lt_iff_matchLen x y u i j (hxsplit ▸ hx_take_sub) hy_drop_sub).mp hbr
          have hyr_drop_m : (y.drop j).Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have h1 : (y.drop j).Sublist (u.drop (matchLenR (y.drop j) u)) :=
              matchLenR_drop_sublist (y.drop j) u hy_drop_sub
            have h2 : (u.drop (matchLenR (y.drop j) u)).Sublist (u.drop (matchLen (x.take (i+1)) u)) := by
              rw [show matchLenR (y.drop j) u = matchLen (x.take (i+1)) u + (matchLenR (y.drop j) u - matchLen (x.take (i+1)) u) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - j) ≤ N := by omega
          have hW := ih (i + 1) j (matchLen (x.take (i + 1)) u) hmeas (le_refl _)
            (hxs_eq ▸ hxs_drop) hyr_drop_m
            (fun hk => matchLen_take_strict_mono x u hx (i + 1) hk)
            (fun _ => hlt_le)
          rw [hxs_eq, hyj] at hW
          exact emb_step a _ u p (matchLen (x.take (i + 1)) u) (by omega) ha hW
        | gt =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have hxsplit : x.take (i + 1) = x.take i ++ [a] := by rw [List.take_add, hxi]; rfl
          have hm_eq : matchLen (x.take (i + 1)) u
              = matchLen (x.take i) u + matchLen [a] (u.drop (matchLen (x.take i) u)) := by
            rw [hxsplit, matchLen_append]
          have hpm : p < matchLen (x.take (i + 1)) u := hxnext hilt
          have hba : matchLen [a] (u.drop p) = matchLen (x.take (i + 1)) u - p := by
            rw [hm_eq] at hpm ⊢; exact blue_advance a u (matchLen (x.take i) u) p hcur hpm
          have hxr' : (a :: xs).Sublist (u.drop p) := hxi ▸ hxr
          have hxs_drop : xs.Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have := sublist_drop_single a xs (u.drop p) hxr'
            rwa [List.drop_drop, hba, Nat.add_sub_cancel' (by omega : p ≤ matchLen (x.take (i+1)) u)] at this
          have hx_take_sub : (x.take (i + 1)).Sublist u := (List.take_sublist _ _).trans hx
          have hy_drop_sub : (y.drop j).Sublist u := (List.drop_sublist _ _).trans hy
          have hy_drop_sub1 : (y.drop (j + 1)).Sublist u := (List.drop_sublist _ _).trans hy
          have ha_pos : u[matchLen (x.take (i + 1)) u - 1]? = some a := by
            have h := matchLen_getElem_last (x.take i) a u (by rw [← hxsplit]; exact hx_take_sub)
            rwa [← hxsplit] at h
          set q := matchLenR (b :: ys) u with hq
          have hbys_sub : (b :: ys).Sublist u := hyj ▸ hy_drop_sub
          have hpq : p ≤ q := by rw [hq, ← hyj]; exact hynext hjlt
          have hmb_le : matchLen [b] (u.drop p) ≤ q + 1 - p :=
            matchLen_single_le_matchLenR b ys u p hbys_sub hpq
          have hbp : [b].Sublist (u.drop p) :=
            List.singleton_sublist.mpr ((hyj ▸ hyr : (b :: ys).Sublist (u.drop p)).subset (by simp))
          have hnt2 : ¬ (x.take (i+1) ++ y.drop (j+1)).Sublist u := by
            unfold brCmp at hbr
            by_cases h1 : (x.take (i+1) ++ y.drop j).Sublist u
            · rw [if_pos h1] at hbr; exact absurd hbr (by simp)
            · rw [if_neg h1] at hbr
              by_cases h2 : (x.take (i+1) ++ y.drop (j+1)).Sublist u
              · rw [if_pos h2] at hbr; exact absurd hbr (by simp)
              · exact h2
          have hgt_mr : matchLenR (y.drop (j+1)) u < matchLen (x.take (i + 1)) u := by
            have h := (append_sublist_iff_matchLen _ _ _ hx_take_sub hy_drop_sub1).not.mp hnt2
            omega
          have hred_mono : q < matchLenR (y.drop (j+1)) u := by
            rw [hys_eq]; exact matchLenR_cons_lt b ys u hbys_sub
          have hxr_q1 : (x.drop i).Sublist (u.drop (q + 1)) := by
            rw [hxi]
            have ha'' : [a].Sublist ((u.drop (matchLen (x.take (i+1)) u - 1)).take 1) := by
              apply List.singleton_sublist.mpr
              have h2 : ((u.drop (matchLen (x.take (i+1)) u - 1)).take 1)[0]? = some a := by
                rw [List.getElem?_take_of_lt (by omega), List.getElem?_drop, Nat.add_zero]; exact ha_pos
              exact List.mem_of_getElem? h2
            have hac : (a :: xs).Sublist (u.drop (matchLen (x.take (i+1)) u - 1)) :=
              emb_step a xs u (matchLen (x.take (i+1)) u - 1) (matchLen (x.take (i+1)) u) (by omega)
                (by rw [show matchLen (x.take (i+1)) u - (matchLen (x.take (i+1)) u - 1) = 1 from by omega]; exact ha'') hxs_drop
            have hsuf : (u.drop (matchLen (x.take (i+1)) u - 1)).Sublist (u.drop (q+1)) := by
              rw [show matchLen (x.take (i+1)) u - 1 = (q+1) + (matchLen (x.take (i+1)) u - 1 - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact hac.trans hsuf
          have hyr_q1 : (y.drop (j+1)).Sublist (u.drop (q + 1)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j+1)) u hy_drop_sub1
            have h2 : (u.drop (matchLenR (y.drop (j+1)) u)).Sublist (u.drop (q+1)) := by
              rw [show matchLenR (y.drop (j+1)) u = (q+1) + (matchLenR (y.drop (j+1)) u - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have ha_b : [b].Sublist ((u.drop p).take (q + 1 - p)) :=
            (matchLen_take_sublist [b] (u.drop p) hbp).trans (List.take_sublist_take_left hmb_le)
          have hmeas : (x.length - i) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih i (j + 1) (q + 1) hmeas (by omega) hxr_q1 hyr_q1
            (fun _ => by omega) (fun _ => by omega)
          rw [hxi, hys_eq] at hW
          exact emb_step b _ u p (q + 1) (by omega) ha_b hW

        | eq =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have htest2 : (x.take (i + 1) ++ y.drop (j + 1)).Sublist u := by
            unfold brCmp at hbr
            by_cases h1 : (x.take (i+1) ++ y.drop j).Sublist u
            · rw [if_pos h1] at hbr; exact absurd hbr (by simp)
            · rw [if_neg h1] at hbr
              by_cases h2 : (x.take (i+1) ++ y.drop (j+1)).Sublist u
              · exact h2
              · rw [if_neg h2] at hbr; exact absurd hbr (by simp)
          have hxsplit : x.take (i + 1) = x.take i ++ [a] := by rw [List.take_add, hxi]; rfl
          have hm_eq : matchLen (x.take (i + 1)) u
              = matchLen (x.take i) u + matchLen [a] (u.drop (matchLen (x.take i) u)) := by
            rw [hxsplit, matchLen_append]
          have hpm : p < matchLen (x.take (i + 1)) u := hxnext hilt
          have hba : matchLen [a] (u.drop p) = matchLen (x.take (i + 1)) u - p := by
            rw [hm_eq] at hpm ⊢; exact blue_advance a u (matchLen (x.take i) u) p hcur hpm
          have hxr' : (a :: xs).Sublist (u.drop p) := hxi ▸ hxr
          have ha_in : [a].Sublist (u.drop p) :=
            List.singleton_sublist.mpr (hxr'.subset (by simp))
          have ha : [a].Sublist ((u.drop p).take (matchLen (x.take (i + 1)) u - p)) := by
            rw [← hba]; exact matchLen_take_sublist [a] (u.drop p) ha_in
          have hxs_drop : xs.Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have := sublist_drop_single a xs (u.drop p) hxr'
            rwa [List.drop_drop, hba, Nat.add_sub_cancel' (by omega : p ≤ matchLen (x.take (i+1)) u)] at this
          have hx_take_sub : (x.take (i + 1)).Sublist u := (List.take_sublist _ _).trans hx
          have hy_drop_sub : (y.drop (j + 1)).Sublist u := (List.drop_sublist _ _).trans hy
          have hle2 : matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop (j + 1)) u :=
            (append_sublist_iff_matchLen _ _ _ (hxsplit ▸ hx_take_sub) hy_drop_sub).mp htest2
          have hyr_drop_m : (y.drop (j + 1)).Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j + 1)) u hy_drop_sub
            have h2 : (u.drop (matchLenR (y.drop (j+1)) u)).Sublist (u.drop (matchLen (x.take (i+1)) u)) := by
              rw [show matchLenR (y.drop (j+1)) u = matchLen (x.take (i+1)) u + (matchLenR (y.drop (j+1)) u - matchLen (x.take (i+1)) u) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih (i + 1) (j + 1) (matchLen (x.take (i + 1)) u) hmeas (le_refl _)
            (hxs_eq ▸ hxs_drop) (hys_eq ▸ hyr_drop_m)
            (fun hk => matchLen_take_strict_mono x u hx (i + 1) hk)
            (fun _ => hle2)
          rw [hxs_eq, hys_eq] at hW
          exact emb_step a _ u p (matchLen (x.take (i + 1)) u) (by omega) ha hW

/-- **`shuffleWord x y u ⊑ u`** — the test-merge of two subwords embeds in `u`. -/
theorem shuffleWord_sublist {α : Type*} [DecidableEq α] (x y u : List α)
    (hx : x.Sublist u) (hy : y.Sublist u) : (shuffleWord x y u).Sublist u := by
  have h := merge_sub x y u hx hy (x.length + y.length) 0 0 0 (by omega)
    (by simp [matchLen]) (by simpa using hx) (by simpa using hy)
    (fun hk => by have := matchLen_take_strict_mono x u hx 0 hk; simpa [matchLen] using this)
    (fun _ => Nat.zero_le _)
  simpa [shuffleWord] using h

/-- **Value-at-gap.** For a position `q` lying between the leftmost ends of the `i`-th and
`(i+1)`-th blue letters of `u`, the running value `φ(u.take q)` equals `φ(u_left.take i)`: the
value is *constant* across a non-blue gap. Pure (no J-triviality); via `leftmost_bound`. This is
the alignment that makes the red letters of `ū` *value-fixers* — the `core_insert`-free route. -/
theorem value_at_gap {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (u : List α) (i q : ℕ)
    (hi : i ≤ (reduceWord φ 1 u).length)
    (hq1 : matchLen ((reduceWord φ 1 u).take i) u ≤ q)
    (hq2 : q < matchLen ((reduceWord φ 1 u).take (i + 1)) u) :
    φ (FreeMonoid.ofList (u.take q)) = φ (FreeMonoid.ofList ((reduceWord φ 1 u).take i)) := by
  set x := reduceWord φ 1 u with hx
  have hpre : (reduceWord φ 1 (u.take q)).IsPrefix x := reduceWord_take_prefix φ u q
  have hxi_u : (x.take i).Sublist u := (List.take_sublist i x).trans (reduceWord_sublist φ u)
  have hsub_take : (x.take i).Sublist (u.take q) :=
    (matchLen_take_sublist (x.take i) u hxi_u).trans (List.take_sublist_take_left hq1)
  have hlen_ge : i ≤ (reduceWord φ 1 (u.take q)).length := leftmost_bound φ u q i hi hsub_take
  obtain ⟨t, ht⟩ := hpre
  have hlen_le : (reduceWord φ 1 (u.take q)).length ≤ i := by
    by_contra hc
    rw [not_le] at hc
    have hl_eq : reduceWord φ 1 (u.take q) = x.take (reduceWord φ 1 (u.take q)).length := by
      rw [← ht, List.take_left]
    have hp1 : (x.take (i + 1)).Sublist (reduceWord φ 1 (u.take q)) := by
      rw [hl_eq]; exact List.take_sublist_take_left (by omega)
    have hs : (x.take (i + 1)).Sublist (u.take q) := hp1.trans (reduceWord_sublist φ (u.take q))
    have := matchLen_le (x.take (i + 1)) u q hs
    omega
  have hlen_eq : (reduceWord φ 1 (u.take q)).length = i := by omega
  have heq : reduceWord φ 1 (u.take q) = x.take i := by rw [← ht, List.take_left' hlen_eq]
  have hspec := reduceWord_spec φ 1 (u.take q)
  rw [heq] at hspec
  simpa using hspec.symm

/-- **Value-at-end.** Past the leftmost end of the last blue letter, the running value is `φ(u)`:
all remaining letters are value-fixers. Pure; via `leftmost_bound`. Used for the *trailing reds*
of `ū` (reds emitted after every blue is consumed). -/
theorem value_at_end {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (u : List α) (q : ℕ)
    (hq : matchLen (reduceWord φ 1 u) u ≤ q) :
    φ (FreeMonoid.ofList (u.take q)) = φ (FreeMonoid.ofList u) := by
  set x := reduceWord φ 1 u with hx
  have hx_u : x.Sublist u := reduceWord_sublist φ u
  have hsub : x.Sublist (u.take q) :=
    (matchLen_take_sublist x u hx_u).trans (List.take_sublist_take_left hq)
  have hpre : (reduceWord φ 1 (u.take q)).IsPrefix x := reduceWord_take_prefix φ u q
  have hge : x.length ≤ (reduceWord φ 1 (u.take q)).length :=
    leftmost_bound φ u q x.length (le_refl _) (by rw [List.take_length]; exact hsub)
  have hle : (reduceWord φ 1 (u.take q)).length ≤ x.length := hpre.length_le
  have hlen : (reduceWord φ 1 (u.take q)).length = x.length := le_antisymm hle hge
  obtain ⟨t, ht⟩ := hpre
  have heq : reduceWord φ 1 (u.take q) = x := by
    have := List.take_left' (l₁ := reduceWord φ 1 (u.take q)) (l₂ := t) hlen
    rw [ht] at this; rw [← this, List.take_length]
  have hspec := reduceWord_spec φ 1 (u.take q)
  rw [heq] at hspec
  have hspecu := reduceWord_spec φ 1 u
  simp only [← hx] at hspecu
  rw [hspecu] at hspec
  simpa using hspec.symm

/-- **Dual of `value_at_end`** (right-anchored, "free" via `Mᵐᵒᵖ`): once the dropped suffix is
short enough that `v.drop p` still contains the entire red skeleton (`redSkel φ v`), the suffix
value is already `φ(v)` — the deleted prefix is all right-fixers. This is `value_at_end (opPhi φ)
v.reverse` translated by `opPhi_ofList`; it is the right-side ingredient the `bridge_v` value
induction needs, obtained with no new induction. -/
theorem suffix_value_at_end {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (v : List α) (p : ℕ)
    (hpe : matchLen (reduceWord (opPhi φ) 1 v.reverse) v.reverse ≤ v.length - p) :
    φ (FreeMonoid.ofList (v.drop p)) = φ (FreeMonoid.ofList v) := by
  have h := value_at_end (opPhi φ) v.reverse (v.length - p) hpe
  rw [opPhi_ofList, opPhi_ofList, ← List.reverse_drop] at h
  simp only [List.reverse_reverse] at h
  exact MulOpposite.op_injective h

/-- **Dual of `value_at_gap`** (right-anchored): in the `t`-th red gap (no suffix-value change),
the suffix value `φ(v.drop p)` is fixed, equal to `φ` of the first `t` red letters read from the
right. `value_at_gap (opPhi φ) v.reverse` translated by `opPhi_ofList`. -/
theorem suffix_value_at_gap {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (v : List α) (t p : ℕ)
    (ht : t ≤ (redSkel φ v).length)
    (hq1 : matchLen ((redSkel φ v).take t) v.reverse ≤ v.length - p)
    (hq2 : v.length - p < matchLen ((redSkel φ v).take (t + 1)) v.reverse) :
    φ (FreeMonoid.ofList (v.drop p)) = φ (FreeMonoid.ofList ((redSkel φ v).take t).reverse) := by
  have h := value_at_gap (opPhi φ) v.reverse t (v.length - p) ht hq1 hq2
  rw [opPhi_ofList, opPhi_ofList, ← List.reverse_drop] at h
  simp only [List.reverse_reverse] at h
  exact MulOpposite.op_injective h

/-- **Index bridge** for the dual side: the rightmost start of the `j`-truncated red word in `v`
is `|v|` minus the leftmost end of the matching red-skeleton prefix in `v.reverse`. Converts the
merge's `matchLenR`-on-`v` cursor bounds into `suffix_value_at_gap`'s `matchLen`-on-`v.reverse`
gap bounds. -/
theorem matchLenR_redWord_drop {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (v : List α) (j : ℕ) :
    matchLenR ((redSkel φ v).reverse.drop j) v
      = v.length - matchLen ((redSkel φ v).take ((redSkel φ v).length - j)) v.reverse := by
  rw [matchLenR]
  congr 2
  rw [List.reverse_drop, List.reverse_reverse, List.length_reverse]

/-- **Per-step suffix-fixer** for the `bridge_v` value induction: two cursor positions `p ≤ q`
lying in the *same red-gap* `j` (no suffix-value change between, i.e.
`matchLenR (y.drop (j-1)) v < p ≤ q ≤ matchLenR (y.drop j) v` with `y = (redSkel φ v).reverse`)
have equal suffix value. Gap `0` is handled by `suffix_value_at_end` (value `= φ v`), gaps `j ≥ 1`
by `suffix_value_at_gap`; bounds converted via `matchLenR_redWord_drop`. -/
theorem suffix_fixer {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (v : List α) (j p q : ℕ)
    (hj : j ≤ (redSkel φ v).length)
    (hpq : p ≤ q) (hqu : q ≤ matchLenR ((redSkel φ v).reverse.drop j) v)
    (hpl : j = 0 ∨ matchLenR ((redSkel φ v).reverse.drop (j - 1)) v < p) :
    φ (FreeMonoid.ofList (v.drop p)) = φ (FreeMonoid.ofList (v.drop q)) := by
  have hbridge : ∀ j', matchLen ((redSkel φ v).take ((redSkel φ v).length - j')) v.reverse
      = v.length - matchLenR ((redSkel φ v).reverse.drop j') v := by
    intro j'
    have hmldr := matchLenR_redWord_drop φ v j'
    have hb := matchLen_le_length ((redSkel φ v).take ((redSkel φ v).length - j')) v.reverse
    rw [List.length_reverse] at hb
    omega
  have hMRle : ∀ j', matchLenR ((redSkel φ v).reverse.drop j') v ≤ v.length := by
    intro j'; rw [matchLenR]; omega
  rcases Nat.eq_zero_or_pos j with hj0 | hjpos
  · subst hj0
    have h0 := hbridge 0
    simp only [Nat.sub_zero, List.take_length, List.drop_zero] at h0 hqu
    rw [suffix_value_at_end φ v p (show matchLen (redSkel φ v) v.reverse ≤ v.length - p by omega),
        suffix_value_at_end φ v q (show matchLen (redSkel φ v) v.reverse ≤ v.length - q by omega)]
  · have hb1 := hbridge j
    have hb2 := hbridge (j - 1)
    have hidx : (redSkel φ v).length - j + 1 = (redSkel φ v).length - (j - 1) := by omega
    have hMj := hMRle j
    have hMj1 := hMRle (j - 1)
    have hpl' : matchLenR ((redSkel φ v).reverse.drop (j - 1)) v < p := by
      rcases hpl with h | h
      · omega
      · exact h
    have key : ∀ s, matchLenR ((redSkel φ v).reverse.drop (j - 1)) v < s →
        s ≤ matchLenR ((redSkel φ v).reverse.drop j) v →
        φ (FreeMonoid.ofList (v.drop s))
          = φ (FreeMonoid.ofList ((redSkel φ v).take ((redSkel φ v).length - j)).reverse) := by
      intro s hsl hsu
      refine suffix_value_at_gap φ v ((redSkel φ v).length - j) s (by omega) (by omega) ?_
      rw [hidx]; omega
    rw [key p hpl' (by omega), key q (by omega) hqu]

/-- **`φ(v_right) = φ(v)`** — the red word has the same value as `v` (`reduceWord_spec` in the
opposite monoid, translated by `opPhi_ofList`). -/
theorem redWord_value {α : Type*} {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (v : List α) :
    φ (FreeMonoid.ofList ((redSkel φ v).reverse)) = φ (FreeMonoid.ofList v) := by
  have h := reduceWord_spec (opPhi φ) 1 v.reverse
  simp only [one_mul] at h
  show φ (FreeMonoid.ofList ((reduceWord (opPhi φ) 1 v.reverse).reverse)) = _
  rw [opPhi_ofList, opPhi_ofList, List.reverse_reverse] at h
  exact MulOpposite.op_injective h

/-- **Reds-dump value**: when the blues are exhausted the merge dumps the remaining reds
`(redSkel φ v).reverse.drop j`; their value equals the suffix value `φ(v.drop p)` (cursor `p` in
red-gap `j`). Via the list identity `y.drop j = ((redSkel φ v).take (|y|−j)).reverse` and
`suffix_value_at_gap` (gap `j ≥ 1`) / `redWord_value`+`suffix_value_at_end` (gap `0`). -/
theorem reds_dump_value {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (v : List α) (j p : ℕ)
    (hj : j ≤ (redSkel φ v).length)
    (hpu : p ≤ matchLenR ((redSkel φ v).reverse.drop j) v)
    (hpl : j = 0 ∨ matchLenR ((redSkel φ v).reverse.drop (j - 1)) v < p) :
    φ (FreeMonoid.ofList ((redSkel φ v).reverse.drop j)) = φ (FreeMonoid.ofList (v.drop p)) := by
  have hrev : ((redSkel φ v).reverse.drop j).reverse = (redSkel φ v).take ((redSkel φ v).length - j) := by
    rw [List.reverse_drop, List.reverse_reverse, List.length_reverse]
  have hlisteq : (redSkel φ v).reverse.drop j = ((redSkel φ v).take ((redSkel φ v).length - j)).reverse := by
    have := congrArg List.reverse hrev; rwa [List.reverse_reverse] at this
  have hbu1 := matchLen_le_length ((redSkel φ v).take ((redSkel φ v).length - j)) v.reverse
  rw [List.length_reverse] at hbu1
  rw [hlisteq]
  rcases Nat.eq_zero_or_pos j with hj0 | hjpos
  · subst hj0
    simp only [Nat.sub_zero, List.take_length, List.drop_zero] at *
    have hmr : matchLenR ((redSkel φ v).reverse) v = v.length - matchLen (redSkel φ v) v.reverse := by
      rw [matchLenR, List.reverse_reverse]
    have hbu : matchLen (redSkel φ v) v.reverse ≤ v.length := by
      have := matchLen_le_length (redSkel φ v) v.reverse; rwa [List.length_reverse] at this
    rw [redWord_value,
        suffix_value_at_end φ v p (by show matchLen (redSkel φ v) v.reverse ≤ v.length - p; omega)]
  · have hb1 := matchLenR_redWord_drop φ v j
    have hb2 := matchLenR_redWord_drop φ v (j - 1)
    have hbu2 := matchLen_le_length ((redSkel φ v).take ((redSkel φ v).length - (j - 1))) v.reverse
    rw [List.length_reverse] at hbu2
    have hMj1 : matchLenR ((redSkel φ v).reverse.drop (j - 1)) v ≤ v.length := by rw [matchLenR]; omega
    have hpl' : matchLenR ((redSkel φ v).reverse.drop (j - 1)) v < p := by
      rcases hpl with h | h
      · omega
      · exact h
    have hidx : (redSkel φ v).length - j + 1 = (redSkel φ v).length - (j - 1) := by omega
    have hsv := suffix_value_at_gap φ v ((redSkel φ v).length - j) p (by omega) (by omega) (by rw [hidx]; omega)
    exact hsv.symm

/-- `φ(ofList w) = 1` when every letter of `w` has `φ`-image `1`. -/
theorem ofList_phi_one {α : Type*} {M : Type*} [Monoid M] (φ : FreeMonoid α →* M) (w : List α)
    (h : ∀ c ∈ w, φ (FreeMonoid.of c) = 1) : φ (FreeMonoid.ofList w) = 1 := by
  induction w with
  | nil => simp
  | cons c w' ih =>
    rw [FreeMonoid.ofList_cons, map_mul, h c (by simp),
        ih (fun c hc => h c (by simp [hc])), one_mul]

/-- **Blues-dump value**: when the reds are exhausted the merge dumps the remaining blues, which
lie in the changer-free region (`φ(v.drop pos) = 1` for all `pos ≥ p`); each is a value-`1` letter,
so the dumped word has value `1`. -/
theorem blues_dump_value {α : Type*} {M : Type*} [Monoid M]
    (φ : FreeMonoid α →* M) (v : List α) (p : ℕ) (w : List α)
    (hw : w.Sublist (v.drop p))
    (hpast : ∀ pos, p ≤ pos → pos ≤ v.length → φ (FreeMonoid.ofList (v.drop pos)) = 1) :
    φ (FreeMonoid.ofList w) = 1 := by
  apply ofList_phi_one
  intro c hc
  have hcd : c ∈ v.drop p := hw.subset hc
  rw [List.mem_iff_getElem] at hcd
  obtain ⟨k, hk, hck⟩ := hcd
  rw [List.length_drop] at hk
  rw [List.getElem_drop] at hck
  have hpos : p + k < v.length := by omega
  have h1 : φ (FreeMonoid.ofList (v.drop (p + k))) = 1 := hpast (p + k) (by omega) (by omega)
  have h2 : φ (FreeMonoid.ofList (v.drop (p + k + 1))) = 1 := hpast (p + k + 1) (by omega) (by omega)
  have hcons : v.drop (p + k) = v[p + k] :: v.drop (p + k + 1) := List.drop_eq_getElem_cons hpos
  rw [hcons, FreeMonoid.ofList_cons, map_mul, h2, mul_one] at h1
  rw [← hck]; exact h1

/-- **Coincidence ⟸ same letter.** In the `brCmp = eq` case, *if* the leftmost blue end
`v[matchLen (x.take (i+1)) v − 1]` carries the same letter as the next red `y[j]`, then the
rightmost red start `matchLenR (y.drop j) v` *equals* that blue position. Proof: the `eq` test
puts `y.drop (j+1)` after the blue end (`matchLen_append_sublist`), and same-letter lets the whole
`y.drop j` embed *starting at* the blue position, so its rightmost start is `≥` it; the `eq`
characterization gives `≤`. This discharges the only obstacle to the `bridge_v` value induction
*modulo* establishing the same letter — which is the remaining `∼ₖ`-dependent Claim-2 core. -/
theorem coincidence_of_sameLetter {α : Type*} [DecidableEq α] (x y v : List α) (i j : ℕ)
    (hb : (x.take (i + 1)).Sublist v) (hr0 : (y.drop j).Sublist v)
    (hr1 : (y.drop (j + 1)).Sublist v) (hj : j < y.length)
    (heq : brCmp x y v i j = Ordering.eq)
    (hsame : v[matchLen (x.take (i + 1)) v - 1]? = y[j]?) :
    matchLenR (y.drop j) v = matchLen (x.take (i + 1)) v - 1 := by
  set M := matchLen (x.take (i + 1)) v with hM
  have hchar := (brCmp_eq_iff_matchLen x y v i j hb hr0 hr1).mp heq
  have hMpos : 1 ≤ M := by omega
  have hMlen : M ≤ v.length := matchLen_le_length _ _
  have hB : (x.take (i + 1) ++ y.drop (j + 1)).Sublist v := ((brCmp_eq_iff x y v i j).mp heq).2
  have hy1 : (y.drop (j + 1)).Sublist (v.drop M) := matchLen_append_sublist _ _ _ hB
  have hMv : M - 1 < v.length := by omega
  have hvcons : v.drop (M - 1) = v[M - 1] :: v.drop M := by
    have h := List.drop_eq_getElem_cons hMv; rwa [show M - 1 + 1 = M from by omega] at h
  have hycons : y.drop j = y[j] :: y.drop (j + 1) := List.drop_eq_getElem_cons hj
  have hyget : y[j]? = some y[j] := List.getElem?_eq_getElem hj
  have hvget : v[M - 1]? = some v[M - 1] := List.getElem?_eq_getElem hMv
  have hsl : v[M - 1] = y[j] := by rw [hvget, hyget] at hsame; exact Option.some.inj hsame
  have hsub : (y.drop j).Sublist (v.drop (M - 1)) := by
    rw [hycons, hvcons, hsl]; exact hy1.cons₂ _
  have hsubr : (y.drop j).reverse.Sublist (v.reverse.take (v.length - (M - 1))) := by
    rw [← List.reverse_drop]; exact hsub.reverse
  have hle := matchLen_le (y.drop j).reverse v.reverse (v.length - (M - 1)) hsubr
  have hge : matchLenR (y.drop j) v ≥ M - 1 := by rw [matchLenR]; omega
  omega

/-- **Trailing reds fix `φ(u)`.** Every letter of a subword living entirely past the last blue
end is a value-fixer of `φ(u)`, so the whole word multiplies `φ(u)` to itself. Via
`value_at_end`. This is the base case (all blues consumed, reds remain) of the value merge. -/
theorem reds_fix_tail {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (u : List α) :
    ∀ w : List α, w.Sublist (u.drop (matchLen (reduceWord φ 1 u) u)) →
      φ (FreeMonoid.ofList u) * φ (FreeMonoid.ofList w) = φ (FreeMonoid.ofList u) := by
  intro w
  induction w with
  | nil => intro _; simp
  | cons c w' ih =>
    intro hsub
    set m := matchLen (reduceWord φ 1 u) u with hm
    have hc_sub : [c].Sublist (u.drop m) :=
      List.singleton_sublist.mpr (hsub.subset (by simp))
    have hw'_sub : w'.Sublist (u.drop m) := (List.sublist_cons_self c w').trans hsub
    have hne : u.drop m ≠ [] := by
      intro hnil; rw [hnil] at hc_sub; exact absurd hc_sub (by simp)
    set d := matchLen [c] (u.drop m) with hd
    have hd_pos : 1 ≤ d := matchLen_single_pos c (u.drop m) hne
    have hget : (u.drop m)[d - 1]? = some c := matchLen_single_get? c (u.drop m) hc_sub
    have huget : u[m + (d - 1)]? = some c := by rw [List.getElem?_drop] at hget; exact hget
    have htake : u.take (m + (d - 1) + 1) = u.take (m + (d - 1)) ++ [c] := by
      rw [List.take_add_one, huget]; rfl
    have hve1 : φ (FreeMonoid.ofList (u.take (m + (d - 1)))) = φ (FreeMonoid.ofList u) :=
      value_at_end φ u (m + (d - 1)) (by rw [← hm]; omega)
    have hve2 : φ (FreeMonoid.ofList (u.take (m + (d - 1) + 1))) = φ (FreeMonoid.ofList u) :=
      value_at_end φ u (m + (d - 1) + 1) (by rw [← hm]; omega)
    have hc_fix : φ (FreeMonoid.ofList u) * φ (FreeMonoid.of c) = φ (FreeMonoid.ofList u) := by
      rw [htake, FreeMonoid.ofList_append, map_mul, hve1] at hve2
      simpa using hve2
    rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hc_fix, ih hw'_sub]

/-- **`value_merge`** — value-tracking twin of `merge_sub`. With the same two-cursor
invariant, the merge of the blue skeleton `x = reduceWord φ 1 u` and any subword `y ⊑ u`
satisfies `φ(x.take i) · φ(mergeO … (x.drop i) (y.drop j) i j) = φ(u)`: blue steps advance the
value (`φ(x.take i)·φ a = φ(x.take (i+1))`), red steps are *fixers* (`value_at_gap` at `q,q+1`),
trailing reds close via `reds_fix_tail`, exhausted lists via `φ(x)=φ(u)`. `core_insert`-free. -/
theorem value_merge {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (x y u : List α)
    (hxred : x = reduceWord φ 1 u) (hy : y.Sublist u) :
    ∀ (N i j p : ℕ), (x.length - i) + (y.length - j) ≤ N →
      matchLen (x.take i) u ≤ p →
      (x.drop i).Sublist (u.drop p) → (y.drop j).Sublist (u.drop p) →
      (i < x.length → p < matchLen (x.take (i + 1)) u) →
      (j < y.length → p ≤ matchLenR (y.drop j) u) →
      φ (FreeMonoid.ofList (x.take i)) *
          φ (FreeMonoid.ofList (mergeO (brCmp x y u) (x.drop i) (y.drop j) i j))
        = φ (FreeMonoid.ofList u) := by
  have hx : x.Sublist u := hxred ▸ reduceWord_sublist φ u
  have hxu_val : φ (FreeMonoid.ofList x) = φ (FreeMonoid.ofList u) := by
    have := reduceWord_spec φ 1 u; rw [← hxred] at this; simpa using this
  intro N
  induction N with
  | zero =>
    intro i j p hN _ _ _ _ _
    rw [List.drop_eq_nil_of_le (by omega : x.length ≤ i),
        List.drop_eq_nil_of_le (by omega : y.length ≤ j), mergeO,
        List.take_of_length_le (by omega : x.length ≤ i)]
    simp [hxu_val]
  | succ N ih =>
    intro i j p hN hcur hxr hyr hxnext hynext
    rcases hxi : x.drop i with _ | ⟨a, xs⟩
    · rw [mergeO]
      have hile : x.length ≤ i := by
        by_contra hc; rw [not_le] at hc
        exact (by rw [← List.length_pos_iff_ne_nil, List.length_drop]; omega : x.drop i ≠ []) hxi
      rw [List.take_of_length_le hile, hxu_val]
      have hp_ge : matchLen x u ≤ p := by
        have := hcur; rwa [List.take_of_length_le hile] at this
      have hsuf : (u.drop p).Sublist (u.drop (matchLen x u)) := by
        rw [show p = matchLen x u + (p - matchLen x u) from by omega, ← List.drop_drop]
        exact List.drop_sublist _ _
      have hyr2 : (y.drop j).Sublist (u.drop (matchLen (reduceWord φ 1 u) u)) := by
        rw [← hxred]; exact hyr.trans hsuf
      exact reds_fix_tail φ u (y.drop j) hyr2
    · rcases hyj : y.drop j with _ | ⟨b, ys⟩
      · rw [mergeO, ← hxi, ← map_mul, ← FreeMonoid.ofList_append, List.take_append_drop, hxu_val]
      · have hilt : i < x.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hxi; exact absurd hxi (by simp)
        have hjlt : j < y.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hyj; exact absurd hyj (by simp)
        have hxs_eq : x.drop (i + 1) = xs := by rw [← List.tail_drop, hxi, List.tail_cons]
        have hxsplit : x.take (i + 1) = x.take i ++ [a] := by rw [List.take_add, hxi]; rfl
        have hval_step : φ (FreeMonoid.ofList (x.take i)) * φ (FreeMonoid.of a)
            = φ (FreeMonoid.ofList (x.take (i + 1))) := by
          rw [hxsplit, FreeMonoid.ofList_append, map_mul]; rfl
        have hm_eq : matchLen (x.take (i + 1)) u
            = matchLen (x.take i) u + matchLen [a] (u.drop (matchLen (x.take i) u)) := by
          rw [hxsplit, matchLen_append]
        have hpm : p < matchLen (x.take (i + 1)) u := hxnext hilt
        have hba : matchLen [a] (u.drop p) = matchLen (x.take (i + 1)) u - p := by
          rw [hm_eq] at hpm ⊢; exact blue_advance a u (matchLen (x.take i) u) p hcur hpm
        have hxr' : (a :: xs).Sublist (u.drop p) := hxi ▸ hxr
        have hxs_drop : xs.Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
          have := sublist_drop_single a xs (u.drop p) hxr'
          rwa [List.drop_drop, hba, Nat.add_sub_cancel' (by omega : p ≤ matchLen (x.take (i+1)) u)] at this
        have hx_take_sub : (x.take (i + 1)).Sublist u := (List.take_sublist _ _).trans hx
        have hy_drop_sub : (y.drop j).Sublist u := (List.drop_sublist _ _).trans hy
        rw [mergeO]
        cases hbr : brCmp x y u i j with
        | lt =>
          have hlt_le : matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop j) u :=
            (brCmp_lt_iff_matchLen x y u i j (hxsplit ▸ hx_take_sub) hy_drop_sub).mp hbr
          have hyr_drop_m : (y.drop j).Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have h1 : (y.drop j).Sublist (u.drop (matchLenR (y.drop j) u)) :=
              matchLenR_drop_sublist (y.drop j) u hy_drop_sub
            have h2 : (u.drop (matchLenR (y.drop j) u)).Sublist (u.drop (matchLen (x.take (i+1)) u)) := by
              rw [show matchLenR (y.drop j) u = matchLen (x.take (i+1)) u + (matchLenR (y.drop j) u - matchLen (x.take (i+1)) u) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - j) ≤ N := by omega
          have hW := ih (i + 1) j (matchLen (x.take (i + 1)) u) hmeas (le_refl _)
            (hxs_eq ▸ hxs_drop) hyr_drop_m
            (fun hk => matchLen_take_strict_mono x u hx (i + 1) hk)
            (fun _ => hlt_le)
          rw [hxs_eq, hyj] at hW
          rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hval_step]
          exact hW
        | gt =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have hy_drop_sub1 : (y.drop (j + 1)).Sublist u := (List.drop_sublist _ _).trans hy
          have ha_pos : u[matchLen (x.take (i + 1)) u - 1]? = some a := by
            have h := matchLen_getElem_last (x.take i) a u (by rw [← hxsplit]; exact hx_take_sub)
            rwa [← hxsplit] at h
          set q := matchLenR (b :: ys) u with hq
          have hbys_sub : (b :: ys).Sublist u := hyj ▸ hy_drop_sub
          have hpq : p ≤ q := by rw [hq, ← hyj]; exact hynext hjlt
          have hnt2 : ¬ (x.take (i+1) ++ y.drop (j+1)).Sublist u := by
            unfold brCmp at hbr
            by_cases h1 : (x.take (i+1) ++ y.drop j).Sublist u
            · rw [if_pos h1] at hbr; exact absurd hbr (by simp)
            · rw [if_neg h1] at hbr
              by_cases h2 : (x.take (i+1) ++ y.drop (j+1)).Sublist u
              · rw [if_pos h2] at hbr; exact absurd hbr (by simp)
              · exact h2
          have hgt_mr : matchLenR (y.drop (j+1)) u < matchLen (x.take (i + 1)) u := by
            have h := (append_sublist_iff_matchLen _ _ _ hx_take_sub hy_drop_sub1).not.mp hnt2
            omega
          have hred_mono : q < matchLenR (y.drop (j+1)) u := by
            rw [hys_eq]; exact matchLenR_cons_lt b ys u hbys_sub
          have hxr_q1 : (x.drop i).Sublist (u.drop (q + 1)) := by
            rw [hxi]
            have ha'' : [a].Sublist ((u.drop (matchLen (x.take (i+1)) u - 1)).take 1) := by
              apply List.singleton_sublist.mpr
              have h2 : ((u.drop (matchLen (x.take (i+1)) u - 1)).take 1)[0]? = some a := by
                rw [List.getElem?_take_of_lt (by omega), List.getElem?_drop, Nat.add_zero]; exact ha_pos
              exact List.mem_of_getElem? h2
            have hac : (a :: xs).Sublist (u.drop (matchLen (x.take (i+1)) u - 1)) :=
              emb_step a xs u (matchLen (x.take (i+1)) u - 1) (matchLen (x.take (i+1)) u) (by omega)
                (by rw [show matchLen (x.take (i+1)) u - (matchLen (x.take (i+1)) u - 1) = 1 from by omega]; exact ha'') hxs_drop
            have hsuf : (u.drop (matchLen (x.take (i+1)) u - 1)).Sublist (u.drop (q+1)) := by
              rw [show matchLen (x.take (i+1)) u - 1 = (q+1) + (matchLen (x.take (i+1)) u - 1 - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact hac.trans hsuf
          have hyr_q1 : (y.drop (j+1)).Sublist (u.drop (q + 1)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j+1)) u hy_drop_sub1
            have h2 : (u.drop (matchLenR (y.drop (j+1)) u)).Sublist (u.drop (q+1)) := by
              rw [show matchLenR (y.drop (j+1)) u = (q+1) + (matchLenR (y.drop (j+1)) u - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hi_le : i ≤ (reduceWord φ 1 u).length := by rw [← hxred]; omega
          have hvag_q : φ (FreeMonoid.ofList (u.take q)) = φ (FreeMonoid.ofList (x.take i)) := by
            have := value_at_gap φ u i q hi_le (by rw [← hxred]; omega) (by rw [← hxred]; omega)
            rw [← hxred] at this; exact this
          have hvag_q1 : φ (FreeMonoid.ofList (u.take (q+1))) = φ (FreeMonoid.ofList (x.take i)) := by
            have := value_at_gap φ u i (q+1) hi_le (by rw [← hxred]; omega) (by rw [← hxred]; omega)
            rw [← hxred] at this; exact this
          have hbq : u[q]? = some b := by rw [hq]; exact matchLenR_get? b ys u hbys_sub
          have htake_b : u.take (q+1) = u.take q ++ [b] := by rw [List.take_add_one, hbq]; rfl
          have hb_fix : φ (FreeMonoid.ofList (x.take i)) * φ (FreeMonoid.of b)
              = φ (FreeMonoid.ofList (x.take i)) := by
            have e1 : φ (FreeMonoid.ofList (u.take (q+1)))
                = φ (FreeMonoid.ofList (u.take q)) * φ (FreeMonoid.of b) := by
              rw [htake_b, FreeMonoid.ofList_append, map_mul]; rfl
            rw [hvag_q1, hvag_q] at e1; exact e1.symm
          have hmeas : (x.length - i) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih i (j + 1) (q + 1) hmeas (by omega) hxr_q1 hyr_q1
            (fun _ => by omega) (fun _ => by omega)
          rw [hxi, hys_eq] at hW
          rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hb_fix]
          exact hW
        | eq =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have htest2 : (x.take (i + 1) ++ y.drop (j + 1)).Sublist u := by
            unfold brCmp at hbr
            by_cases h1 : (x.take (i+1) ++ y.drop j).Sublist u
            · rw [if_pos h1] at hbr; exact absurd hbr (by simp)
            · rw [if_neg h1] at hbr
              by_cases h2 : (x.take (i+1) ++ y.drop (j+1)).Sublist u
              · exact h2
              · rw [if_neg h2] at hbr; exact absurd hbr (by simp)
          have hy_drop_sub' : (y.drop (j + 1)).Sublist u := (List.drop_sublist _ _).trans hy
          have hle2 : matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop (j + 1)) u :=
            (append_sublist_iff_matchLen _ _ _ (hxsplit ▸ hx_take_sub) hy_drop_sub').mp htest2
          have hyr_drop_m : (y.drop (j + 1)).Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j + 1)) u hy_drop_sub'
            have h2 : (u.drop (matchLenR (y.drop (j+1)) u)).Sublist (u.drop (matchLen (x.take (i+1)) u)) := by
              rw [show matchLenR (y.drop (j+1)) u = matchLen (x.take (i+1)) u + (matchLenR (y.drop (j+1)) u - matchLen (x.take (i+1)) u) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih (i + 1) (j + 1) (matchLen (x.take (i + 1)) u) hmeas (le_refl _)
            (hxs_eq ▸ hxs_drop) (hys_eq ▸ hyr_drop_m)
            (fun hk => matchLen_take_strict_mono x u hx (i + 1) hk)
            (fun _ => hle2)
          rw [hxs_eq, hys_eq] at hW
          rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hval_step]
          exact hW


/-- **`φ(shuffleWord) = φ(u)`** at `i=j=p=0` — Klíma's Claim 1 closure for the blue/red merge,
with no J-trivial subword theorem. This is the value half of the bridge (`shuffleWord_sublist`
is the embedding half). -/
theorem shuffleWord_value {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (x y u : List α)
    (hxred : x = reduceWord φ 1 u) (hy : y.Sublist u) :
    φ (FreeMonoid.ofList (shuffleWord x y u)) = φ (FreeMonoid.ofList u) := by
  have hx : x.Sublist u := hxred ▸ reduceWord_sublist φ u
  have h := value_merge φ x y u hxred hy (x.length + y.length) 0 0 0 (by omega)
    (by simp [matchLen]) (by simpa using hx) (by simpa using hy)
    (fun hk => by have := matchLen_take_strict_mono x u hx 0 hk; simpa [matchLen] using this)
    (fun _ => Nat.zero_le _)
  simpa [shuffleWord] using h

/-! ### Value side — Claim 1 closure, reduced to one J-trivial monoid fact

Claim 1 (`φ(ū) = φ(u)` from `u_left ⊑ ū ⊑ u`) is a *sandwiching*. With `φ(u_left) = φ(u)`
(`reduceWord_spec`) it follows from antisymmetry of `≤𝓙` (which `IsJTrivial` gives) plus the
**subword order refines the J-order**: `x ⊑ w ⟹ φ(w) ≤𝓙 φ(x)`. That in turn reduces, by a
context induction, to the single atomic fact

    `core_insert : ∀ P A Y, P·A·Y ≤𝓙 P·Y`   (inserting a letter descends in `≤𝓙`),

the standard property of finite J-trivial monoids. Everything below is verified *modulo*
`core_insert` (threaded as an explicit premise — no `sorry`). -/

/-- Generalised subword→J-order with a left context `P`. Skip case uses `core_insert`. -/
theorem subword_jle_gen {M : Type*} [Monoid M] (φ : FreeMonoid α →* M)
    (core_insert : ∀ P A Y : M, greenJLe (P * A * Y) (P * Y)) :
    ∀ (x u : List α), x.Sublist u → ∀ P : M,
      greenJLe (P * φ (FreeMonoid.ofList u)) (P * φ (FreeMonoid.ofList x)) := by
  intro x u h
  induction h with
  | slnil => intro P; simpa using greenJLe_refl _
  | cons a h ih =>
    intro P
    rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc]
    exact greenJLe_trans (core_insert P (φ (FreeMonoid.of a)) _) (ih P)
  | cons₂ a h ih =>
    intro P
    rw [FreeMonoid.ofList_cons, map_mul, FreeMonoid.ofList_cons, map_mul, ← mul_assoc, ← mul_assoc]
    exact ih (P * φ (FreeMonoid.of a))

/-- **Subword order refines the J-order** (reduced to `core_insert`). -/
theorem subword_jle {M : Type*} [Monoid M] (φ : FreeMonoid α →* M)
    (core_insert : ∀ P A Y : M, greenJLe (P * A * Y) (P * Y))
    (x w : List α) (h : x.Sublist w) :
    greenJLe (φ (FreeMonoid.ofList w)) (φ (FreeMonoid.ofList x)) := by
  have := subword_jle_gen φ core_insert x w h 1
  simpa using this

/-- **Sandwiching = Klíma's Claim 1**: if `skel(u) ⊑ r ⊑ u` then `φ(r) = φ(u)`. Reduced to
`core_insert` via `subword_jle` and antisymmetry of `≤𝓙`. -/
theorem sandwich {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (hJ : IsJTrivial M) (core_insert : ∀ P A Y : M, greenJLe (P * A * Y) (P * Y))
    (u r : List α) (h1 : (reduceWord φ 1 u).Sublist r) (h2 : r.Sublist u) :
    φ (FreeMonoid.ofList r) = φ (FreeMonoid.ofList u) := by
  have hskel : φ (FreeMonoid.ofList (reduceWord φ 1 u)) = φ (FreeMonoid.ofList u) := by
    have := reduceWord_spec φ 1 u; simpa using this
  have hle1 : greenJLe (φ (FreeMonoid.ofList r)) (φ (FreeMonoid.ofList u)) := by
    have h := subword_jle φ core_insert _ _ h1; rwa [hskel] at h
  have hle2 : greenJLe (φ (FreeMonoid.ofList u)) (φ (FreeMonoid.ofList r)) :=
    subword_jle φ core_insert _ _ h2
  exact hJ _ _ ⟨hle1, hle2⟩

/-! ### Claim 1 (value side) — the on-critical-path proof (Klíma's positions + congruence)

Klíma's Claim 1 keeps every value-*changer* (blue) and deletes only value-*fixers*; by the
congruence this preserves `φ`. Formalised as a scan `maskKeep` that forces all changers and
admits an arbitrary fixer "extras" mask — this is *always* a `GoodSub`, so `φ` is preserved
unconditionally. This is the real Claim-1 value step (the `sandwich`/`core_insert` route above
is the off-path alternative). -/

/-- Scan `u` keeping every value-changer plus the fixers flagged `true` in `es` (extras shorter
than `u` count `false`). `ū` viewed structurally: blue letters forced, red letters as extras. -/
def maskKeep {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M) :
    M → List Bool → List α → List α
  | _, _, [] => []
  | val, es, a :: u =>
    if val * φ (FreeMonoid.of a) = val then
      (if es.headD false then a :: maskKeep φ val es.tail u else maskKeep φ val es.tail u)
    else a :: maskKeep φ (val * φ (FreeMonoid.of a)) es.tail u

/-- **`maskKeep` is always a `GoodSub`** (all changers kept; only fixers as extras). -/
theorem goodsub_maskKeep {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M) :
    ∀ (val : M) (es : List Bool) (u : List α), GoodSub φ val (maskKeep φ val es u) u := by
  intro val es u
  induction u generalizing val es with
  | nil => exact GoodSub.nil val
  | cons a u' ih =>
    rw [maskKeep]
    by_cases hfix : val * φ (FreeMonoid.of a) = val
    · rw [if_pos hfix]
      by_cases he : es.headD false
      · rw [if_pos he]; exact GoodSub.keepFixer hfix (ih val es.tail)
      · rw [if_neg he]; exact GoodSub.skip hfix (ih val es.tail)
    · rw [if_neg hfix]; exact GoodSub.keep (ih (val * φ (FreeMonoid.of a)) es.tail)

/-- **Value side of Claim 1**: any `maskKeep` of `u` has the same `φ` as `u`. Unconditional —
no `core_insert`, no J-triviality, just `GoodSub`. -/
theorem maskKeep_phi {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (es : List Bool) (u : List α) :
    φ (FreeMonoid.ofList (maskKeep φ 1 es u)) = φ (FreeMonoid.ofList u) :=
  (goodsub_maskKeep φ 1 es u).value_one

/-- **Dual Claim 1 closure** (the `core_insert`-free `bridge_v` ingredient): any *right* maskKeep
of `v` — read `v` right-to-left in `Mᵐᵒᵖ`, keep the suffix-changers plus chosen fixer-extras `es`,
reverse back — has the same `φ`-value as `v`. The `opPhi` mirror of `maskKeep_phi`. This gives
`φ(v̄')=φ(v)` for the **position-union** `v̄'` (which keeps every red position), independently of
the goal — unlike the `mergeO`-`v̄` whose `bridge_v` is circular. -/
theorem right_maskKeep_phi {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (es : List Bool) (v : List α) :
    φ (FreeMonoid.ofList ((maskKeep (opPhi φ) 1 es v.reverse).reverse))
      = φ (FreeMonoid.ofList v) := by
  have h := maskKeep_phi (opPhi φ) es v.reverse
  rw [opPhi_ofList, opPhi_ofList, List.reverse_reverse] at h
  exact MulOpposite.op_injective h

/-! ### Position comparator `pcmp` — the corrected merge for the position-union `bridge_v`

`brCmp`'s `eq` case mis-fires (it emits the blue and *drops* the red whenever the blue falls in a
red-gap, even at *different* letters — this is exactly why `klima_sameLetter` is FALSE). The fix is
to compare the blue/red **positions** directly: `pcmp` is `eq` only at *genuine coincidence*
(blue position = red position), so `mergeO (pcmp …)` keeps **every** red position — the
position-union `v̄'`. Its `bridge_v` is then non-circular (`right_maskKeep_phi` / dual Claim 1
applies because no red is dropped), and `ū' = v̄'` reduces to `pcmp` agreement under `∼ₖ`. -/

/-- Compare the leftmost `(i+1)`-blue position (`matchLen (x.take (i+1)) w − 1`) with the rightmost
`j`-red position (`matchLenR (y.drop j) w`), via `matchLen ⋚ matchLenR + 1`. -/
def pcmp {α : Type*} [DecidableEq α] (x y w : List α) (i j : ℕ) : Ordering :=
  compare (matchLen (x.take (i + 1)) w) (matchLenR (y.drop j) w + 1)

/-- `pcmp = lt` ⟺ blue strictly before red — the same subword test as `brCmp = lt`. -/
theorem pcmp_lt_iff {α : Type*} [DecidableEq α] (x y w : List α) (i j : ℕ) :
    pcmp x y w i j = Ordering.lt ↔ matchLen (x.take (i + 1)) w ≤ matchLenR (y.drop j) w := by
  unfold pcmp; rw [Nat.compare_eq_lt]; omega

/-- `pcmp = eq` ⟺ exact coincidence of the blue and red positions. -/
theorem pcmp_eq_iff {α : Type*} [DecidableEq α] (x y w : List α) (i j : ℕ) :
    pcmp x y w i j = Ordering.eq ↔ matchLen (x.take (i + 1)) w = matchLenR (y.drop j) w + 1 := by
  unfold pcmp; rw [Nat.compare_eq_eq]

/-- `pcmp = gt` ⟺ red strictly before blue. -/
theorem pcmp_gt_iff {α : Type*} [DecidableEq α] (x y w : List α) (i j : ℕ) :
    pcmp x y w i j = Ordering.gt ↔ matchLenR (y.drop j) w + 1 < matchLen (x.take (i + 1)) w := by
  unfold pcmp; rw [Nat.compare_eq_gt]

/-- **The order-determination bridge.** `pcmp`'s coincidence (`eq`) is exactly `brCmp = eq` *plus*
the two carried letters agreeing (`x[i]? = y[j]?`). Since `brCmp` transfers under `∼ₖ` and the
letters `x[i]?, y[j]?` are word-independent, this is what lets `pcmp x y u = pcmp x y v` — hence
the position-unions `ū' = v̄'` (Klíma's Claim 2). Uses the banked `coincidence_of_sameLetter`. -/
theorem pcmp_eq_iff_brCmp {α : Type*} [DecidableEq α] (x y w : List α) (i j : ℕ)
    (hb : (x.take (i + 1)).Sublist w) (hr0 : (y.drop j).Sublist w)
    (hr1 : (y.drop (j + 1)).Sublist w) (hi : i < x.length) (hj : j < y.length) :
    pcmp x y w i j = Ordering.eq ↔ (brCmp x y w i j = Ordering.eq ∧ x[i]? = y[j]?) := by
  rw [pcmp_eq_iff]
  have hxsplit : x.take (i + 1) = x.take i ++ [x[i]] := by
    rw [List.take_add_one, List.getElem?_eq_getElem hi]; rfl
  have hMpos : 1 ≤ matchLen (x.take (i + 1)) w := by
    have hs := matchLen_append_strict (x.take i) (x[i]) w (by rw [← hxsplit]; exact hb)
    rw [← hxsplit] at hs; omega
  have hblue : w[matchLen (x.take (i + 1)) w - 1]? = x[i]? := by
    have hg := matchLen_getElem_last (x.take i) (x[i]) w (by rw [← hxsplit]; exact hb)
    rw [← hxsplit] at hg; rw [hg, List.getElem?_eq_getElem hi]
  have hycons : y.drop j = y[j] :: y.drop (j + 1) := List.drop_eq_getElem_cons hj
  have hbys : (y[j] :: y.drop (j + 1)).Sublist w := hycons ▸ hr0
  have hred : w[matchLenR (y.drop j) w]? = y[j]? := by
    have hg := matchLenR_get? (y[j]) (y.drop (j + 1)) w hbys
    rw [← hycons] at hg; rw [hg, List.getElem?_eq_getElem hj]
  have hmono : matchLenR (y.drop j) w < matchLenR (y.drop (j + 1)) w := by
    rw [hycons]; exact matchLenR_cons_lt _ _ _ hbys
  constructor
  · intro hM
    refine ⟨(brCmp_eq_iff_matchLen x y w i j hb hr0 hr1).mpr ⟨by omega, by omega⟩, ?_⟩
    have hxR : w[matchLenR (y.drop j) w]? = x[i]? := by
      rw [show matchLenR (y.drop j) w = matchLen (x.take (i + 1)) w - 1 from by omega]; exact hblue
    rw [hred] at hxR; exact hxR.symm
  · rintro ⟨heq, hsame⟩
    have hsame' : w[matchLen (x.take (i + 1)) w - 1]? = y[j]? := by rw [hblue, hsame]
    have := coincidence_of_sameLetter x y w i j hb hr0 hr1 hj heq hsame'
    omega

/-- **Order-determination (in range).** For consulted positions `p < |x|`, `q < |y|`, the position
comparator agrees in `u` and `v`: `pcmp x y u p q = pcmp x y v p q`. The `lt` boundary is the
subword test `(x.take (p+1) ++ y.drop q) ⊑ ·` (transfers by `∼ₖ`); the `eq` boundary is
`brCmp = eq ∧ x[p]? = y[q]?` (`brCmp` transfers, letters are fixed). -/
theorem pcmp_agree {α : Type*} [DecidableEq α] (x y u v : List α) (k : ℕ)
    (hk : x.length + y.length ≤ k)
    (hsim : ∀ z : List α, z.length ≤ k → (z.Sublist u ↔ z.Sublist v))
    (hxu0 : x.Sublist u) (hyv0 : y.Sublist v)
    (p q : ℕ) (hp : p < x.length) (hq : q < y.length) :
    pcmp x y u p q = pcmp x y v p q := by
  have hxu : (x.take (p + 1)).Sublist u := (List.take_sublist _ _).trans hxu0
  have hyv : (y.drop q).Sublist v := (List.drop_sublist _ _).trans hyv0
  have hy1v : (y.drop (q + 1)).Sublist v := (List.drop_sublist _ _).trans hyv0
  have hxlen : (x.take (p + 1)).length ≤ k := by rw [List.length_take]; omega
  have hylen : (y.drop q).length ≤ k := by rw [List.length_drop]; omega
  have hy1len : (y.drop (q + 1)).length ≤ k := by rw [List.length_drop]; omega
  have hxv : (x.take (p + 1)).Sublist v := (hsim _ hxlen).mp hxu
  have hyu : (y.drop q).Sublist u := (hsim _ hylen).mpr hyv
  have hy1u : (y.drop (q + 1)).Sublist u := (hsim _ hy1len).mpr hy1v
  have hlt_u : pcmp x y u p q = Ordering.lt ↔ (x.take (p + 1) ++ y.drop q).Sublist u := by
    rw [pcmp_lt_iff]; exact (append_sublist_iff_matchLen _ _ u hxu hyu).symm
  have hlt_v : pcmp x y v p q = Ordering.lt ↔ (x.take (p + 1) ++ y.drop q).Sublist v := by
    rw [pcmp_lt_iff]; exact (append_sublist_iff_matchLen _ _ v hxv hyv).symm
  have htrans_lt :
      (x.take (p + 1) ++ y.drop q).Sublist u ↔ (x.take (p + 1) ++ y.drop q).Sublist v := by
    apply hsim; rw [List.length_append, List.length_take, List.length_drop]; omega
  have Hlt : pcmp x y u p q = Ordering.lt ↔ pcmp x y v p q = Ordering.lt :=
    hlt_u.trans (htrans_lt.trans hlt_v.symm)
  have heq_u := pcmp_eq_iff_brCmp x y u p q hxu hyu hy1u hp hq
  have heq_v := pcmp_eq_iff_brCmp x y v p q hxv hyv hy1v hp hq
  have hbr : brCmp x y u p q = brCmp x y v p q := by rw [brCmp_eq x y u v k hk hsim]
  have Heq : pcmp x y u p q = Ordering.eq ↔ pcmp x y v p q = Ordering.eq := by
    rw [heq_u, heq_v, hbr]
  rcases hu : pcmp x y u p q <;> rcases hv : pcmp x y v p q <;> simp_all

/-- The **position-union** `ū' = mergeO (pcmp …) x y 0 0`: `x`'s and `y`'s letters interleaved by
their *positions* in `w`, never dropping a red. This is Klíma's `bar` construction done right. -/
def posUnion {α : Type*} [DecidableEq α] (x y w : List α) : List α := mergeO (pcmp x y w) x y 0 0

/-- **Klíma's Claim 2 (`ū' = v̄'`), now correct.** The position-unions over `u` and `v` are the
*same word*, because `mergeO` only consults `pcmp` in the rectangle `[0,|x|) × [0,|y|)` where it
agrees (`pcmp_agree`), and `mergeO_congr` closes it. Unlike the refuted `klima_sameLetter`, this
needs no per-element coincidence — only the position *order*, which `∼ₖ` determines. -/
theorem posUnion_eq {α : Type*} [DecidableEq α] (x y u v : List α) (k : ℕ)
    (hk : x.length + y.length ≤ k)
    (hsim : ∀ z : List α, z.length ≤ k → (z.Sublist u ↔ z.Sublist v))
    (hxu0 : x.Sublist u) (hyv0 : y.Sublist v) :
    posUnion x y u = posUnion x y v := by
  unfold posUnion
  apply mergeO_congr
  intro p q _ hpx _ hqy
  exact pcmp_agree x y u v k hk hsim hxu0 hyv0 p q (by simpa using hpx) (by simpa using hqy)

/-- **`value_merge` for `pcmp`** (Claim 1 closure for the position-union). Identical two-cursor
value induction as `value_merge`, but driven by `pcmp`: the `lt` test is the same; for `gt` the
red `b` is a left-fixer (`value_at_gap`, with `pcmp`'s `matchLen > matchLenR+1` giving the bounds
directly); for `eq` (coincidence) the dropped red sits at the *same position* as the emitted blue,
so the value just steps through. `core_insert`-free. -/
theorem value_merge_pcmp {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (x y u : List α)
    (hxred : x = reduceWord φ 1 u) (hy : y.Sublist u) :
    ∀ (N i j p : ℕ), (x.length - i) + (y.length - j) ≤ N →
      matchLen (x.take i) u ≤ p →
      (x.drop i).Sublist (u.drop p) → (y.drop j).Sublist (u.drop p) →
      (i < x.length → p < matchLen (x.take (i + 1)) u) →
      (j < y.length → p ≤ matchLenR (y.drop j) u) →
      φ (FreeMonoid.ofList (x.take i)) *
          φ (FreeMonoid.ofList (mergeO (pcmp x y u) (x.drop i) (y.drop j) i j))
        = φ (FreeMonoid.ofList u) := by
  have hx : x.Sublist u := hxred ▸ reduceWord_sublist φ u
  have hxu_val : φ (FreeMonoid.ofList x) = φ (FreeMonoid.ofList u) := by
    have := reduceWord_spec φ 1 u; rw [← hxred] at this; simpa using this
  intro N
  induction N with
  | zero =>
    intro i j p hN _ _ _ _ _
    rw [List.drop_eq_nil_of_le (by omega : x.length ≤ i),
        List.drop_eq_nil_of_le (by omega : y.length ≤ j), mergeO,
        List.take_of_length_le (by omega : x.length ≤ i)]
    simp [hxu_val]
  | succ N ih =>
    intro i j p hN hcur hxr hyr hxnext hynext
    rcases hxi : x.drop i with _ | ⟨a, xs⟩
    · rw [mergeO]
      have hile : x.length ≤ i := by
        by_contra hc; rw [not_le] at hc
        exact (by rw [← List.length_pos_iff_ne_nil, List.length_drop]; omega : x.drop i ≠ []) hxi
      rw [List.take_of_length_le hile, hxu_val]
      have hp_ge : matchLen x u ≤ p := by
        have := hcur; rwa [List.take_of_length_le hile] at this
      have hsuf : (u.drop p).Sublist (u.drop (matchLen x u)) := by
        rw [show p = matchLen x u + (p - matchLen x u) from by omega, ← List.drop_drop]
        exact List.drop_sublist _ _
      have hyr2 : (y.drop j).Sublist (u.drop (matchLen (reduceWord φ 1 u) u)) := by
        rw [← hxred]; exact hyr.trans hsuf
      exact reds_fix_tail φ u (y.drop j) hyr2
    · rcases hyj : y.drop j with _ | ⟨b, ys⟩
      · rw [mergeO, ← hxi, ← map_mul, ← FreeMonoid.ofList_append, List.take_append_drop, hxu_val]
      · have hilt : i < x.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hxi; exact absurd hxi (by simp)
        have hjlt : j < y.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hyj; exact absurd hyj (by simp)
        have hxs_eq : x.drop (i + 1) = xs := by rw [← List.tail_drop, hxi, List.tail_cons]
        have hxsplit : x.take (i + 1) = x.take i ++ [a] := by rw [List.take_add, hxi]; rfl
        have hval_step : φ (FreeMonoid.ofList (x.take i)) * φ (FreeMonoid.of a)
            = φ (FreeMonoid.ofList (x.take (i + 1))) := by
          rw [hxsplit, FreeMonoid.ofList_append, map_mul]; rfl
        have hm_eq : matchLen (x.take (i + 1)) u
            = matchLen (x.take i) u + matchLen [a] (u.drop (matchLen (x.take i) u)) := by
          rw [hxsplit, matchLen_append]
        have hpm : p < matchLen (x.take (i + 1)) u := hxnext hilt
        have hba : matchLen [a] (u.drop p) = matchLen (x.take (i + 1)) u - p := by
          rw [hm_eq] at hpm ⊢; exact blue_advance a u (matchLen (x.take i) u) p hcur hpm
        have hxr' : (a :: xs).Sublist (u.drop p) := hxi ▸ hxr
        have hxs_drop : xs.Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
          have := sublist_drop_single a xs (u.drop p) hxr'
          rwa [List.drop_drop, hba, Nat.add_sub_cancel' (by omega : p ≤ matchLen (x.take (i+1)) u)] at this
        have hx_take_sub : (x.take (i + 1)).Sublist u := (List.take_sublist _ _).trans hx
        have hy_drop_sub : (y.drop j).Sublist u := (List.drop_sublist _ _).trans hy
        rw [mergeO]
        cases hpc : pcmp x y u i j with
        | lt =>
          have hlt_le : matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop j) u :=
            (pcmp_lt_iff x y u i j).mp hpc
          have hyr_drop_m : (y.drop j).Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have h1 : (y.drop j).Sublist (u.drop (matchLenR (y.drop j) u)) :=
              matchLenR_drop_sublist (y.drop j) u hy_drop_sub
            have h2 : (u.drop (matchLenR (y.drop j) u)).Sublist (u.drop (matchLen (x.take (i+1)) u)) := by
              rw [show matchLenR (y.drop j) u = matchLen (x.take (i+1)) u + (matchLenR (y.drop j) u - matchLen (x.take (i+1)) u) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - j) ≤ N := by omega
          have hW := ih (i + 1) j (matchLen (x.take (i + 1)) u) hmeas (le_refl _)
            (hxs_eq ▸ hxs_drop) hyr_drop_m
            (fun hk => matchLen_take_strict_mono x u hx (i + 1) hk)
            (fun _ => hlt_le)
          rw [hxs_eq, hyj] at hW
          rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hval_step]
          exact hW
        | gt =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have hy_drop_sub1 : (y.drop (j + 1)).Sublist u := (List.drop_sublist _ _).trans hy
          have ha_pos : u[matchLen (x.take (i + 1)) u - 1]? = some a := by
            have h := matchLen_getElem_last (x.take i) a u (by rw [← hxsplit]; exact hx_take_sub)
            rwa [← hxsplit] at h
          set q := matchLenR (b :: ys) u with hq
          have hbys_sub : (b :: ys).Sublist u := hyj ▸ hy_drop_sub
          have hpq : p ≤ q := by rw [hq, ← hyj]; exact hynext hjlt
          have hgt : matchLenR (y.drop j) u + 1 < matchLen (x.take (i + 1)) u :=
            (pcmp_gt_iff x y u i j).mp hpc
          have hqv : q = matchLenR (y.drop j) u := by rw [hq, hyj]
          have hred_mono : q < matchLenR (y.drop (j+1)) u := by
            rw [hys_eq]; exact matchLenR_cons_lt b ys u hbys_sub
          have hxr_q1 : (x.drop i).Sublist (u.drop (q + 1)) := by
            rw [hxi]
            have ha'' : [a].Sublist ((u.drop (matchLen (x.take (i+1)) u - 1)).take 1) := by
              apply List.singleton_sublist.mpr
              have h2 : ((u.drop (matchLen (x.take (i+1)) u - 1)).take 1)[0]? = some a := by
                rw [List.getElem?_take_of_lt (by omega), List.getElem?_drop, Nat.add_zero]; exact ha_pos
              exact List.mem_of_getElem? h2
            have hac : (a :: xs).Sublist (u.drop (matchLen (x.take (i+1)) u - 1)) :=
              emb_step a xs u (matchLen (x.take (i+1)) u - 1) (matchLen (x.take (i+1)) u) (by omega)
                (by rw [show matchLen (x.take (i+1)) u - (matchLen (x.take (i+1)) u - 1) = 1 from by omega]; exact ha'') hxs_drop
            have hsuf : (u.drop (matchLen (x.take (i+1)) u - 1)).Sublist (u.drop (q+1)) := by
              rw [show matchLen (x.take (i+1)) u - 1 = (q+1) + (matchLen (x.take (i+1)) u - 1 - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact hac.trans hsuf
          have hyr_q1 : (y.drop (j+1)).Sublist (u.drop (q + 1)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j+1)) u hy_drop_sub1
            have h2 : (u.drop (matchLenR (y.drop (j+1)) u)).Sublist (u.drop (q+1)) := by
              rw [show matchLenR (y.drop (j+1)) u = (q+1) + (matchLenR (y.drop (j+1)) u - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hi_le : i ≤ (reduceWord φ 1 u).length := by rw [← hxred]; omega
          have hvag_q : φ (FreeMonoid.ofList (u.take q)) = φ (FreeMonoid.ofList (x.take i)) := by
            have := value_at_gap φ u i q hi_le (by rw [← hxred]; omega) (by rw [← hxred]; omega)
            rw [← hxred] at this; exact this
          have hvag_q1 : φ (FreeMonoid.ofList (u.take (q+1))) = φ (FreeMonoid.ofList (x.take i)) := by
            have := value_at_gap φ u i (q+1) hi_le (by rw [← hxred]; omega) (by rw [← hxred]; omega)
            rw [← hxred] at this; exact this
          have hbq : u[q]? = some b := by rw [hq]; exact matchLenR_get? b ys u hbys_sub
          have htake_b : u.take (q+1) = u.take q ++ [b] := by rw [List.take_add_one, hbq]; rfl
          have hb_fix : φ (FreeMonoid.ofList (x.take i)) * φ (FreeMonoid.of b)
              = φ (FreeMonoid.ofList (x.take i)) := by
            have e1 : φ (FreeMonoid.ofList (u.take (q+1)))
                = φ (FreeMonoid.ofList (u.take q)) * φ (FreeMonoid.of b) := by
              rw [htake_b, FreeMonoid.ofList_append, map_mul]; rfl
            rw [hvag_q1, hvag_q] at e1; exact e1.symm
          have hmeas : (x.length - i) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih i (j + 1) (q + 1) hmeas (by omega) hxr_q1 hyr_q1
            (fun _ => by omega) (fun _ => by omega)
          rw [hxi, hys_eq] at hW
          rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hb_fix]
          exact hW
        | eq =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have hy_drop_sub' : (y.drop (j + 1)).Sublist u := (List.drop_sublist _ _).trans hy
          have hbys_sub : (b :: ys).Sublist u := hyj ▸ hy_drop_sub
          have hcoinc : matchLen (x.take (i + 1)) u = matchLenR (y.drop j) u + 1 :=
            (pcmp_eq_iff x y u i j).mp hpc
          have hred_mono : matchLenR (y.drop j) u < matchLenR (y.drop (j+1)) u := by
            rw [hyj, hys_eq]; exact matchLenR_cons_lt b ys u hbys_sub
          have hle2 : matchLen (x.take (i + 1)) u ≤ matchLenR (y.drop (j + 1)) u := by omega
          have hyr_drop_m : (y.drop (j + 1)).Sublist (u.drop (matchLen (x.take (i + 1)) u)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j + 1)) u hy_drop_sub'
            have h2 : (u.drop (matchLenR (y.drop (j+1)) u)).Sublist (u.drop (matchLen (x.take (i+1)) u)) := by
              rw [show matchLenR (y.drop (j+1)) u = matchLen (x.take (i+1)) u + (matchLenR (y.drop (j+1)) u - matchLen (x.take (i+1)) u) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih (i + 1) (j + 1) (matchLen (x.take (i + 1)) u) hmeas (le_refl _)
            (hxs_eq ▸ hxs_drop) (hys_eq ▸ hyr_drop_m)
            (fun hk => matchLen_take_strict_mono x u hx (i + 1) hk)
            (fun _ => hle2)
          rw [hxs_eq, hys_eq] at hW
          rw [FreeMonoid.ofList_cons, map_mul, ← mul_assoc, hval_step]
          exact hW

/-- **`bridge_u` for the position-union**: `φ(posUnion (reduceWord φ 1 u) y u) = φ(u)`. -/
theorem posUnion_value {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (x y u : List α)
    (hxred : x = reduceWord φ 1 u) (hy : y.Sublist u) :
    φ (FreeMonoid.ofList (posUnion x y u)) = φ (FreeMonoid.ofList u) := by
  have hx : x.Sublist u := hxred ▸ reduceWord_sublist φ u
  have h := value_merge_pcmp φ x y u hxred hy (x.length + y.length) 0 0 0 (by omega)
    (by simp [matchLen]) (by simpa using hx) (by simpa using hy)
    (fun hk => by have := matchLen_take_strict_mono x u hx 0 hk; simpa [matchLen] using this)
    (fun _ => Nat.zero_le _)
  simpa [posUnion] using h

/-- **`value_merge_right` for `pcmp`** (dual Claim 1 closure). The right-anchored value induction
of `value_merge_right`, driven by `pcmp`. Crucially it needs **no `hcoin` hypothesis**: the
coincidence equation that doomed the `brCmp` version (`klima_sameLetter`, FALSE) now holds *by
definition* — `pcmp = eq` is exactly `matchLen (x.take (i+1)) v = matchLenR (y.drop j) v + 1`. -/
theorem value_merge_pcmp_right {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (x y v : List α)
    (hyred : y = (redSkel φ v).reverse) (hx : x.Sublist v) :
    ∀ (N i j p : ℕ), (x.length - i) + (y.length - j) ≤ N →
      matchLen (x.take i) v ≤ p → j ≤ y.length → p ≤ v.length →
      (j = 0 ∨ matchLenR (y.drop (j - 1)) v < p) →
      (x.drop i).Sublist (v.drop p) → (y.drop j).Sublist (v.drop p) →
      (i < x.length → p < matchLen (x.take (i + 1)) v) →
      (j < y.length → p ≤ matchLenR (y.drop j) v) →
      φ (FreeMonoid.ofList (mergeO (pcmp x y v) (x.drop i) (y.drop j) i j))
        = φ (FreeMonoid.ofList (v.drop p)) := by
  have hyv : y.Sublist v := hyred ▸ redWord_sublist φ v
  have hylen : y.length = (redSkel φ v).length := by rw [hyred, List.length_reverse]
  have blue_step : ∀ i j p a,
      matchLen (x.take i) v ≤ p → p < matchLen (x.take (i + 1)) v →
      (x.take (i + 1)).Sublist v →
      v[matchLen (x.take (i + 1)) v - 1]? = some a →
      (j = 0 ∨ matchLenR (y.drop (j - 1)) v < p) → j ≤ y.length →
      matchLen (x.take (i + 1)) v - 1 ≤ matchLenR (y.drop j) v →
      φ (FreeMonoid.of a) * φ (FreeMonoid.ofList (v.drop (matchLen (x.take (i + 1)) v)))
        = φ (FreeMonoid.ofList (v.drop p)) := by
    intro i j p a hcur hpm htk hap hglb hjle hbpos
    have hm1 : 1 ≤ matchLen (x.take (i + 1)) v := by omega
    have hml : matchLen (x.take (i + 1)) v ≤ v.length := matchLen_le_length _ _
    have hav : v[matchLen (x.take (i + 1)) v - 1] = a := by
      have := List.getElem?_eq_getElem (show matchLen (x.take (i+1)) v - 1 < v.length by omega)
      rw [this] at hap; exact (Option.some.inj hap)
    have hcons : v.drop (matchLen (x.take (i + 1)) v - 1)
        = a :: v.drop (matchLen (x.take (i + 1)) v) := by
      have h := List.drop_eq_getElem_cons (show matchLen (x.take (i+1)) v - 1 < v.length by omega)
      rw [hav, show matchLen (x.take (i+1)) v - 1 + 1 = matchLen (x.take (i+1)) v from by omega] at h
      exact h
    have hbeq : φ (FreeMonoid.ofList (v.drop (matchLen (x.take (i + 1)) v - 1)))
        = φ (FreeMonoid.of a) * φ (FreeMonoid.ofList (v.drop (matchLen (x.take (i + 1)) v))) := by
      rw [hcons, FreeMonoid.ofList_cons, map_mul]
    have hsf := suffix_fixer φ v j p (matchLen (x.take (i + 1)) v - 1)
      (by rw [← hylen]; exact hjle) (by omega)
      (by rw [hyred] at hbpos; exact hbpos) (by rw [hyred] at hglb; exact hglb)
    rw [← hbeq]; exact hsf.symm
  have red_step : ∀ j p b q, q = matchLenR (y.drop j) v → v[q]? = some b → p ≤ q → q < v.length →
      (j = 0 ∨ matchLenR (y.drop (j - 1)) v < p) → j ≤ y.length →
      φ (FreeMonoid.of b) * φ (FreeMonoid.ofList (v.drop (q + 1)))
        = φ (FreeMonoid.ofList (v.drop p)) := by
    intro j p b q hq hbq hpq hqv hglb hjle
    have hbv : v[q] = b := by
      rw [List.getElem?_eq_getElem hqv] at hbq; exact Option.some.inj hbq
    have hcons : v.drop q = b :: v.drop (q + 1) := by
      have h := List.drop_eq_getElem_cons hqv; rw [hbv] at h; exact h
    have hbeq : φ (FreeMonoid.ofList (v.drop q))
        = φ (FreeMonoid.of b) * φ (FreeMonoid.ofList (v.drop (q + 1))) := by
      rw [hcons, FreeMonoid.ofList_cons, map_mul]
    have hsf := suffix_fixer φ v j p q (by rw [← hylen]; exact hjle) hpq
      (by rw [hyred] at hq; omega) (by rw [hyred] at hglb; exact hglb)
    rw [← hbeq]; exact hsf.symm
  intro N
  induction N with
  | zero =>
    intro i j p hN hcur hjle hpv hglb hxr hyr hxnext hynext
    rw [List.drop_eq_nil_of_le (by omega : x.length ≤ i),
        List.drop_eq_nil_of_le (by omega : y.length ≤ j), mergeO]
    have hjeq : j = (redSkel φ v).length := by rw [← hylen]; omega
    have hempty : (redSkel φ v).reverse.drop (redSkel φ v).length = [] :=
      List.drop_eq_nil_of_le (by rw [List.length_reverse])
    have := reds_dump_value φ v (redSkel φ v).length p (le_refl _)
      (by rw [hempty, show matchLenR ([] : List α) v = v.length from by simp [matchLenR, matchLen]]; exact hpv)
      (by rw [hyred, hjeq] at hglb; exact hglb)
    rw [hempty] at this
    exact this
  | succ N ih =>
    intro i j p hN hcur hjle hpv hglb hxr hyr hxnext hynext
    rcases hxi : x.drop i with _ | ⟨a, xs⟩
    · rw [mergeO, hyred]
      refine reds_dump_value φ v j p (hjle.trans hylen.le) ?_ (by rw [hyred] at hglb; exact hglb)
      rcases lt_or_eq_of_le hjle with hlt | heq
      · rw [← hyred]; exact hynext hlt
      · rw [show (redSkel φ v).reverse.drop j = [] from by
              rw [← hyred, heq]; exact List.drop_eq_nil_of_le (le_refl _),
            show matchLenR ([] : List α) v = v.length from by simp [matchLenR, matchLen]]
        exact hpv
    · rcases hyj : y.drop j with _ | ⟨b, ys⟩
      · rw [mergeO, ← hxi]
        have hge : y.length ≤ j := by rw [List.drop_eq_nil_iff] at hyj; exact hyj
        have hjeq : j = y.length := le_antisymm hjle hge
        have hregion : ∀ pos, p ≤ pos → pos ≤ v.length → φ (FreeMonoid.ofList (v.drop pos)) = 1 := by
          intro pos hp1 hp2
          have hsf := suffix_fixer φ v y.length pos v.length hylen.le hp2
            (by rw [show (redSkel φ v).reverse.drop y.length = [] from by
                      rw [← hyred]; exact List.drop_eq_nil_of_le (le_refl _),
                    show matchLenR ([] : List α) v = v.length from by simp [matchLenR, matchLen]])
            (by rcases Nat.eq_zero_or_pos y.length with h0 | hpos
                · exact Or.inl h0
                · right; rw [hyred] at hglb; rcases hglb with h | h
                  · omega
                  · rw [hjeq] at h; omega)
          rw [show v.drop v.length = [] from List.drop_eq_nil_of_le (le_refl _)] at hsf
          simpa using hsf
        rw [blues_dump_value φ v p (x.drop i) hxr hregion,
            blues_dump_value φ v p (v.drop p) (List.Sublist.refl _) hregion]
      · have hilt : i < x.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hxi; exact absurd hxi (by simp)
        have hjlt : j < y.length := by
          by_contra hc; rw [List.drop_eq_nil_of_le (by omega)] at hyj; exact absurd hyj (by simp)
        have hxs_eq : x.drop (i + 1) = xs := by rw [← List.tail_drop, hxi, List.tail_cons]
        have hxsplit : x.take (i + 1) = x.take i ++ [a] := by rw [List.take_add, hxi]; rfl
        have hx_take_sub : (x.take (i + 1)).Sublist v := (List.take_sublist _ _).trans hx
        have hy_drop_sub : (y.drop j).Sublist v := (List.drop_sublist _ _).trans hyv
        have hpm : p < matchLen (x.take (i + 1)) v := hxnext hilt
        have hml : matchLen (x.take (i + 1)) v ≤ v.length := matchLen_le_length _ _
        have ha_pos : v[matchLen (x.take (i + 1)) v - 1]? = some a := by
          have h := matchLen_getElem_last (x.take i) a v (by rw [← hxsplit]; exact hx_take_sub)
          rwa [← hxsplit] at h
        have hm_eq : matchLen (x.take (i + 1)) v
            = matchLen (x.take i) v + matchLen [a] (v.drop (matchLen (x.take i) v)) := by
          rw [hxsplit, matchLen_append]
        have hba : matchLen [a] (v.drop p) = matchLen (x.take (i + 1)) v - p := by
          rw [hm_eq] at hpm ⊢; exact blue_advance a v (matchLen (x.take i) v) p hcur hpm
        have hxr' : (a :: xs).Sublist (v.drop p) := hxi ▸ hxr
        have hxs_drop : xs.Sublist (v.drop (matchLen (x.take (i + 1)) v)) := by
          have := sublist_drop_single a xs (v.drop p) hxr'
          rwa [List.drop_drop, hba, Nat.add_sub_cancel' (by omega : p ≤ matchLen (x.take (i+1)) v)] at this
        rw [mergeO]
        cases hpc : pcmp x y v i j with
        | lt =>
          have hlt_le : matchLen (x.take (i + 1)) v ≤ matchLenR (y.drop j) v :=
            (pcmp_lt_iff x y v i j).mp hpc
          have hyr_drop_m : (y.drop j).Sublist (v.drop (matchLen (x.take (i + 1)) v)) := by
            have h1 := matchLenR_drop_sublist (y.drop j) v hy_drop_sub
            have h2 : (v.drop (matchLenR (y.drop j) v)).Sublist (v.drop (matchLen (x.take (i+1)) v)) := by
              rw [show matchLenR (y.drop j) v = matchLen (x.take (i+1)) v + (matchLenR (y.drop j) v - matchLen (x.take (i+1)) v) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - j) ≤ N := by omega
          have hW := ih (i + 1) j (matchLen (x.take (i + 1)) v) hmeas (le_refl _) hjle hml
            (by rcases hglb with h | h
                · exact Or.inl h
                · exact Or.inr (by omega))
            (hxs_eq ▸ hxs_drop) hyr_drop_m
            (fun hk => matchLen_take_strict_mono x v hx (i + 1) hk) (fun _ => hlt_le)
          rw [hxs_eq, hyj] at hW
          rw [FreeMonoid.ofList_cons, map_mul, hW]
          exact blue_step i j p a hcur hpm hx_take_sub ha_pos hglb hjle (by omega)
        | gt =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have hy_drop_sub1 : (y.drop (j + 1)).Sublist v := (List.drop_sublist _ _).trans hyv
          have hbys_sub : (b :: ys).Sublist v := hyj ▸ hy_drop_sub
          set q := matchLenR (y.drop j) v with hqdef
          have hbq : v[q]? = some b := by
            rw [hqdef, hyj]; exact matchLenR_get? b ys v hbys_sub
          have hpq : p ≤ q := by rw [hqdef]; exact hynext hjlt
          have hgt : matchLenR (y.drop j) v + 1 < matchLen (x.take (i + 1)) v :=
            (pcmp_gt_iff x y v i j).mp hpc
          have hred_mono : q < matchLenR (y.drop (j+1)) v := by
            rw [hqdef, hyj, hys_eq]; exact matchLenR_cons_lt b ys v hbys_sub
          have hqv : q < v.length := by omega
          have hxr_q1 : (x.drop i).Sublist (v.drop (q + 1)) := by
            rw [hxi]
            have ha'' : [a].Sublist ((v.drop (matchLen (x.take (i+1)) v - 1)).take 1) := by
              apply List.singleton_sublist.mpr
              have h2 : ((v.drop (matchLen (x.take (i+1)) v - 1)).take 1)[0]? = some a := by
                rw [List.getElem?_take_of_lt (by omega), List.getElem?_drop, Nat.add_zero]; exact ha_pos
              exact List.mem_of_getElem? h2
            have hac : (a :: xs).Sublist (v.drop (matchLen (x.take (i+1)) v - 1)) :=
              emb_step a xs v (matchLen (x.take (i+1)) v - 1) (matchLen (x.take (i+1)) v) (by omega)
                (by rw [show matchLen (x.take (i+1)) v - (matchLen (x.take (i+1)) v - 1) = 1 from by omega]; exact ha'') hxs_drop
            have hsuf : (v.drop (matchLen (x.take (i+1)) v - 1)).Sublist (v.drop (q+1)) := by
              rw [show matchLen (x.take (i+1)) v - 1 = (q+1) + (matchLen (x.take (i+1)) v - 1 - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact hac.trans hsuf
          have hyr_q1 : (y.drop (j+1)).Sublist (v.drop (q + 1)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j+1)) v hy_drop_sub1
            have h2 : (v.drop (matchLenR (y.drop (j+1)) v)).Sublist (v.drop (q+1)) := by
              rw [show matchLenR (y.drop (j+1)) v = (q+1) + (matchLenR (y.drop (j+1)) v - (q+1)) from by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - i) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih i (j + 1) (q + 1) hmeas (by omega) (by omega) (by omega)
            (by right; rw [show j + 1 - 1 = j from by omega]; omega)
            hxr_q1 hyr_q1 (fun _ => by omega) (fun _ => by omega)
          rw [hxi, hys_eq] at hW
          rw [FreeMonoid.ofList_cons, map_mul, hW]
          exact red_step j p b q hqdef hbq hpq hqv hglb hjle
        | eq =>
          have hys_eq : y.drop (j + 1) = ys := by rw [← List.tail_drop, hyj, List.tail_cons]
          have hy_drop_sub' : (y.drop (j + 1)).Sublist v := (List.drop_sublist _ _).trans hyv
          have hbys_sub : (b :: ys).Sublist v := hyj ▸ hy_drop_sub
          have hcoin_j : matchLen (x.take (i + 1)) v = matchLenR (y.drop j) v + 1 :=
            (pcmp_eq_iff x y v i j).mp hpc
          have hred_mono : matchLenR (y.drop j) v < matchLenR (y.drop (j+1)) v := by
            rw [hyj, hys_eq]; exact matchLenR_cons_lt b ys v hbys_sub
          have hle2 : matchLen (x.take (i + 1)) v ≤ matchLenR (y.drop (j + 1)) v := by omega
          have hyr_drop_m : (y.drop (j + 1)).Sublist (v.drop (matchLen (x.take (i + 1)) v)) := by
            have h1 := matchLenR_drop_sublist (y.drop (j + 1)) v hy_drop_sub'
            have h2 : (v.drop (matchLenR (y.drop (j+1)) v)).Sublist (v.drop (matchLen (x.take (i+1)) v)) := by
              rw [show matchLenR (y.drop (j+1)) v = matchLen (x.take (i+1)) v + (matchLenR (y.drop (j+1)) v - matchLen (x.take (i+1)) v) by omega, ← List.drop_drop]
              exact List.drop_sublist _ _
            exact h1.trans h2
          have hmeas : (x.length - (i + 1)) + (y.length - (j + 1)) ≤ N := by omega
          have hW := ih (i + 1) (j + 1) (matchLen (x.take (i + 1)) v) hmeas (le_refl _) (by omega) hml
            (by right; rw [show j + 1 - 1 = j from by omega]; omega)
            (hxs_eq ▸ hxs_drop) (hys_eq ▸ hyr_drop_m)
            (fun hk => matchLen_take_strict_mono x v hx (i + 1) hk) (fun _ => hle2)
          rw [hxs_eq, hys_eq] at hW
          rw [FreeMonoid.ofList_cons, map_mul, hW]
          exact blue_step i j p a hcur hpm hx_take_sub ha_pos hglb hjle (by omega)

/-- **`bridge_v` for the position-union** — `φ(posUnion x v_right v) = φ(v)` for any blue `x ⊑ v`,
with `v_right = (redSkel φ v).reverse`. **No coincidence hypothesis** (contrast the dead
`shuffleWord_value_right`): `pcmp` makes it definitional. -/
theorem posUnion_value_right {α : Type*} [DecidableEq α] {M : Type*} [Monoid M] [DecidableEq M]
    (φ : FreeMonoid α →* M) (x v : List α) (hx : x.Sublist v) :
    φ (FreeMonoid.ofList (posUnion x ((redSkel φ v).reverse) v)) = φ (FreeMonoid.ofList v) := by
  have h := value_merge_pcmp_right φ x ((redSkel φ v).reverse) v rfl hx
    (x.length + ((redSkel φ v).reverse).length) 0 0 0 (by omega)
    (by simp [matchLen]) (Nat.zero_le _) (Nat.zero_le _) (Or.inl rfl)
    (by simpa using hx) (by simpa using redWord_sublist φ v)
    (fun hk => by have := matchLen_take_strict_mono x v hx 0 hk; simpa [matchLen] using this)
    (fun _ => Nat.zero_le _)
  simpa [posUnion] using h

/-! ### Length budget (step 2) — `|u_left| < card M`

The post-change values form a list that descends strictly in `≤𝓙` *by construction*; in a
J-trivial monoid `≤𝓙` is a partial order, so the list is `Nodup`, capping its length by
`card M`. -/

/-- The skeleton is idempotent (every kept letter is a genuine changer). -/
theorem reduceWord_idem {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M) :
    ∀ (val : M) (u : List α), reduceWord φ val (reduceWord φ val u) = reduceWord φ val u := by
  intro val u
  induction u generalizing val with
  | nil => simp [reduceWord]
  | cons c u' ih =>
    rw [reduceWord]
    by_cases hc : val * φ (FreeMonoid.of c) = val
    · rw [if_pos hc]; exact ih val
    · rw [if_neg hc, reduceWord, if_neg hc, ih (val * φ (FreeMonoid.of c))]

/-- The list of running values after each value-*change* while scanning `u` from `val`. -/
def vals {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M) : M → List α → List M
  | _, [] => []
  | val, c :: u =>
    if val * φ (FreeMonoid.of c) = val then vals φ val u
    else (val * φ (FreeMonoid.of c)) :: vals φ (val * φ (FreeMonoid.of c)) u

theorem vals_length {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (val : M) (u : List α) : (vals φ val u).length = (reduceWord φ val u).length := by
  induction u generalizing val with
  | nil => simp [vals, reduceWord]
  | cons c u' ih =>
    rw [vals, reduceWord]
    by_cases hc : val * φ (FreeMonoid.of c) = val
    · rw [if_pos hc, if_pos hc]; exact ih val
    · rw [if_neg hc, if_neg hc]; simp [ih]

theorem vals_chain {M : Type*} [Monoid M] [DecidableEq M] (φ : FreeMonoid α →* M)
    (val : M) (u : List α) :
    List.IsChain (fun a b => greenJLe b a ∧ b ≠ a) (val :: vals φ val u) := by
  induction u generalizing val with
  | nil => exact List.IsChain.singleton val
  | cons c u' ih =>
    rw [vals]
    by_cases hc : val * φ (FreeMonoid.of c) = val
    · rw [if_pos hc]; exact ih val
    · rw [if_neg hc]
      exact List.isChain_cons_cons.mpr ⟨⟨⟨1, φ (FreeMonoid.of c), by rw [one_mul]⟩, hc⟩,
        ih (val * φ (FreeMonoid.of c))⟩

/-- **Length budget**: the blue word has fewer letters than the monoid has elements. -/
theorem reduceWord_length_lt {M : Type*} [Monoid M] [DecidableEq M] [Fintype M]
    (hJ : IsJTrivial M) (φ : FreeMonoid α →* M) (u : List α) :
    (reduceWord φ 1 u).length < Fintype.card M := by
  haveI : Trans (fun a b : M => greenJLe b a ∧ b ≠ a) (fun a b => greenJLe b a ∧ b ≠ a)
      (fun a b => greenJLe b a ∧ b ≠ a) :=
    ⟨fun {a b c} hab hbc =>
      ⟨greenJLe_trans hbc.1 hab.1, fun hca => hab.2 (hJ b a ⟨hab.1, hca ▸ hbc.1⟩)⟩⟩
  have hpair := (List.isChain_iff_pairwise).mp (vals_chain φ 1 u)
  have hnodup : (1 :: vals φ 1 u).Nodup := hpair.imp (fun h => h.2.symm)
  have hlen := hnodup.length_le_card
  rw [← vals_length]
  simp only [List.length_cons] at hlen
  omega

/-! ### Dual length budget — `|v_right| < card M`, "for free" via `Mᵐᵒᵖ`

The red word's budget is the blue budget in the opposite monoid: `𝓙`-triviality is a two-sided
property, so it transports through `MulOpposite` (the `𝓙`-order is symmetric under `op`/`unop`),
and `reduceWord_length_lt` applies to `opPhi φ` and `v.reverse`. -/

/-- `≤𝓙` transports into `Mᵐᵒᵖ` (the witnesses `s,t` swap). -/
theorem greenJLe_op {M : Type*} [Monoid M] {a b : M} (h : greenJLe a b) :
    greenJLe (MulOpposite.op a) (MulOpposite.op b) := by
  obtain ⟨s, t, hst⟩ := h
  exact ⟨MulOpposite.op t, MulOpposite.op s, by
    apply MulOpposite.unop_injective; simp [hst, mul_assoc]⟩

/-- `≤𝓙` transports out of `Mᵐᵒᵖ`. -/
theorem greenJLe_unop {M : Type*} [Monoid M] {a b : Mᵐᵒᵖ} (h : greenJLe a b) :
    greenJLe (MulOpposite.unop a) (MulOpposite.unop b) := by
  obtain ⟨s, t, hst⟩ := h
  exact ⟨MulOpposite.unop t, MulOpposite.unop s, by
    have := congrArg MulOpposite.unop hst; simpa [mul_assoc] using this⟩

/-- **`𝓙`-triviality passes to the opposite monoid.** -/
theorem isJTrivial_op {M : Type*} [Monoid M] (hM : IsJTrivial M) : IsJTrivial Mᵐᵒᵖ := by
  intro a b hab
  exact MulOpposite.unop_injective (hM _ _ ⟨greenJLe_unop hab.1, greenJLe_unop hab.2⟩)

/-- **Dual length budget**: the red word has fewer letters than the monoid has elements. -/
theorem redWord_length_lt {M : Type*} [Monoid M] [DecidableEq M] [Fintype M]
    (hJ : IsJTrivial M) (φ : FreeMonoid α →* M) (v : List α) :
    ((redSkel φ v).reverse).length < Fintype.card M := by
  haveI : Fintype Mᵐᵒᵖ := Fintype.ofEquiv M MulOpposite.opEquiv
  rw [List.length_reverse]
  unfold redSkel
  have h := reduceWord_length_lt (isJTrivial_op hJ) (opPhi φ) v.reverse
  rwa [← Fintype.card_congr (MulOpposite.opEquiv (α := M))] at h

/-- **Lemma 3 (Klíma)**: a `𝓙`-trivial syntactic monoid of index `m` makes `∼ₖ` refine `∼_L`
for `k = 2m-2`. **Fully assembled, sorry-free.** The chain `φ(u)=φ(ū')=φ(v̄')=φ(v)` over the
**position-union** `ū'/v̄' = posUnion u_left v_right ·`:
* `bridge_u` (`posUnion_value`): `φ(ū')=φ(u)` — Claim 1 closure (`u_left` = `u`'s left skeleton).
* `ū'=v̄'` (`posUnion_eq`): the position-unions agree, fed by `∼ₖ` and the length budgets
  `reduceWord_length_lt`/`redWord_length_lt` (`k = 2m-2`). This is Klíma's Claim 2 — the
  order-determination — proved via `pcmp_agree`/`mergeO_congr`, **not** the false per-element
  `klima_sameLetter` (refuted: `u=v=[1,1,0,0]`).
* `bridge_v` (`posUnion_value_right`): `φ(v̄')=φ(v)` — dual Claim 1, `core_insert`-free; needs **no**
  coincidence hypothesis because `pcmp`'s `eq` *is* position coincidence by definition.
* chain ⟹ `syntacticCon` via `Con.eq`. -/
theorem subk_refines_of_jtrivial {L : Set (FreeMonoid α)}
    [Finite (SyntacticMonoid L)] (h : IsJTrivial (SyntacticMonoid L)) :
    ∃ k : ℕ, ∀ u v : FreeMonoid α,
      (∀ x : FreeMonoid α, x.length ≤ k → (u ∈ subwordUpset x ↔ v ∈ subwordUpset x)) →
      syntacticCon L u v := by
  classical
  haveI : Fintype (SyntacticMonoid L) := Fintype.ofFinite _
  haveI : Nonempty (SyntacticMonoid L) := ⟨1⟩
  set φ := syntacticMorphism L with hφ
  set m := Fintype.card (SyntacticMonoid L) with hm
  have hmpos : 1 ≤ m := Fintype.card_pos
  refine ⟨2 * m - 2, fun u v hsub => ?_⟩
  have hsim : ∀ z : List α, z.length ≤ 2 * m - 2 →
      (z.Sublist (FreeMonoid.toList u) ↔ z.Sublist (FreeMonoid.toList v)) := by
    intro z hz
    have := hsub (FreeMonoid.ofList z) (by simpa using hz)
    simpa [subwordUpset] using this
  set ul := reduceWord φ 1 (FreeMonoid.toList u) with hul
  set vr := (redSkel φ (FreeMonoid.toList v)).reverse with hvr
  have hulb : ul.length < m := reduceWord_length_lt h φ (FreeMonoid.toList u)
  have hvrb : vr.length < m := redWord_length_lt h φ (FreeMonoid.toList v)
  have hk : ul.length + vr.length ≤ 2 * m - 2 := by omega
  have hul_u : ul.Sublist (FreeMonoid.toList u) := reduceWord_sublist φ (FreeMonoid.toList u)
  have hul_v : ul.Sublist (FreeMonoid.toList v) := (hsim ul (by omega)).mp hul_u
  have hvr_v : vr.Sublist (FreeMonoid.toList v) := redWord_sublist φ (FreeMonoid.toList v)
  have hvr_u : vr.Sublist (FreeMonoid.toList u) := (hsim vr (by omega)).mpr hvr_v
  -- bridge_u (Claim 1): `φ(ū') = φ(u)`, position-union over `u` (`ul` = `u`'s left skeleton).
  have hbu : φ (FreeMonoid.ofList (posUnion ul vr (FreeMonoid.toList u)))
      = φ (FreeMonoid.ofList (FreeMonoid.toList u)) :=
    posUnion_value φ ul vr (FreeMonoid.toList u) rfl hvr_u
  -- Claim 2: `ū' = v̄'`, the position-unions agree (order-determination via `∼ₖ`).
  have heqw : posUnion ul vr (FreeMonoid.toList u) = posUnion ul vr (FreeMonoid.toList v) :=
    posUnion_eq ul vr (FreeMonoid.toList u) (FreeMonoid.toList v) (2 * m - 2) hk hsim hul_u hvr_v
  -- bridge_v (dual Claim 1): `φ(v̄') = φ(v)`, position-union over `v` (`vr` = `v`'s right skeleton).
  -- No coincidence hypothesis — `pcmp` makes it definitional (the false `klima_sameLetter` is gone).
  have hbv : φ (FreeMonoid.ofList (posUnion ul vr (FreeMonoid.toList v)))
      = φ (FreeMonoid.ofList (FreeMonoid.toList v)) := by
    rw [hvr]; exact posUnion_value_right φ ul (FreeMonoid.toList v) hul_v
  have hφuv : φ u = φ v := by
    have e1 : φ (FreeMonoid.ofList (FreeMonoid.toList u)) = φ u := by rw [FreeMonoid.ofList_toList]
    have e2 : φ (FreeMonoid.ofList (FreeMonoid.toList v)) = φ v := by rw [FreeMonoid.ofList_toList]
    rw [← e1, ← e2, ← hbu, heqw, hbv]
  exact (Con.eq (syntacticCon L)).mp hφuv

/-- HARD CORE 3 — Simon's converse: a regular language over a **finite alphabet** whose
syntactic monoid is `𝓙`-trivial is piecewise testable. **Now reduced (sorry-free except
Lemma 3)** to the single combinatorial core `subk_refines_of_jtrivial` (Klíma's Lemma 3),
via the fully-proved wrapping `pt_of_subk_refines` (Lemma 1).

**`[Finite α]` IS REQUIRED — false without it.** Over an infinite alphabet `L = {ε}` has
syntactic monoid `U₁` (finite, `𝓙`-trivial) but is not PT (any finite Boolean combination
of `subwordUpset uᵢ` tests only the finitely many letters in the `uᵢ`; it cannot separate
`ε` from a fresh letter). The forward direction `pt_finite_jtrivial` needs no `[Finite α]`. -/
theorem pt_of_jtrivial (L : Set (FreeMonoid α)) [Finite α] [Finite (SyntacticMonoid L)]
    (h : IsJTrivial (SyntacticMonoid L)) : IsPiecewiseTestable L := by
  obtain ⟨k, href⟩ := subk_refines_of_jtrivial h
  exact pt_of_subk_refines k href

/-- FORWARD direction (`PT ⟹ regular ∧ 𝓙-trivial`), combined induction so finiteness
is threaded. `empty`, `compl`, **and `union`** are CLOSED **fully sorry-free** (the
`union` case now rests on the completely proved `jtrivial_union` →
`isJTrivial_of_surjHom` → `Green.jtrivial_of_identities` chain); only `basic`
(`pt_basic`) delegates to a hard core. -/
theorem pt_finite_jtrivial {L : Set (FreeMonoid α)} (h : IsPiecewiseTestable L) :
    Finite (SyntacticMonoid L) ∧ IsJTrivial (SyntacticMonoid L) := by
  induction h with
  | basic u => exact pt_basic u
  | empty => exact ⟨Finite.of_subsingleton, isJTrivial_of_subsingleton _⟩
  | @compl L _ ih =>
    obtain ⟨fin, jt⟩ := ih
    refine ⟨?_, (isJTrivial_quotient_congr (syntacticCon_compl _)).mpr jt⟩
    rw [syntacticMonoid_compl]; exact fin
  | @union L₁ L₂ _ _ ih₁ ih₂ =>
    obtain ⟨fin₁, jt₁⟩ := ih₁
    obtain ⟨fin₂, jt₂⟩ := ih₂
    haveI := fin₁; haveI := fin₂
    exact ⟨finite_syntacticMonoid_union, jtrivial_union jt₁ jt₂⟩

/-- **Simon's theorem** (I. Simon, *Piecewise testable events*, 1975).
A regular language is piecewise testable iff its syntactic monoid is `𝓙`-trivial.

**Proof status: FULLY PROVED, sorry-free** (`#print axioms simon` = `[propext,
Classical.choice, Quot.sound]`). Both directions are complete:
* **FORWARD (`pt_finite_jtrivial`, `PT ⟹ 𝓙-trivial`)** for any `α` — all four cases
  (`basic` via `pt_basic`, plus `empty`/`compl`/`union` via the quotient-closure chain
  `jtrivial_union` → `isJTrivial_of_surjHom` → `Green.jtrivial_of_identities`).
* **CONVERSE (`pt_of_jtrivial`, `𝓙-trivial ⟹ PT`)**, which needs `[Finite α]` (false over
  infinite alphabets). This is Simon's deep direction = Klíma's Lemma 3
  (`subk_refines_of_jtrivial`): `∼ₖ` refines `∼_L` for `k = 2m−2`, via the **position-union**
  `φ(u)=φ(ū')=φ(v̄')=φ(v)` (`posUnion_value` / `posUnion_eq` / `posUnion_value_right`), with the
  position comparator `pcmp` whose `eq` is genuine coincidence — sidestepping the FALSE
  per-element same-letter claim. `core_insert`-free throughout. -/
theorem simon (L : Set (FreeMonoid α)) [Finite α] [Finite (SyntacticMonoid L)] :
    IsPiecewiseTestable L ↔ IsJTrivial (SyntacticMonoid L) :=
  ⟨fun h => (pt_finite_jtrivial h).2, fun h => pt_of_jtrivial L h⟩

/-- The piecewise-testable languages are closed under intersection (sorry-free,
from the inductive Boolean closure: `L₁ ∩ L₂ = (L₁ᶜ ∪ L₂ᶜ)ᶜ`). -/
theorem IsPiecewiseTestable.inter {L₁ L₂ : Set (FreeMonoid α)}
    (h₁ : IsPiecewiseTestable L₁) (h₂ : IsPiecewiseTestable L₂) :
    IsPiecewiseTestable (L₁ ∩ L₂) := by
  have : L₁ ∩ L₂ = (L₁ᶜ ∪ L₂ᶜ)ᶜ := by
    rw [Set.compl_union, compl_compl, compl_compl]
  rw [this]
  exact (h₁.compl.union h₂.compl).compl

end DualityEngine
